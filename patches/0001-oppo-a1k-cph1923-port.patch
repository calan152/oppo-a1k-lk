+static u32 expdb_append_log_data(part_dev_t *dev, struct log_emmc_header *log_header,
+				 uchar *buf, u32 size)
+{
+	u32 emmc_remain_buf_size;
+	u32 log_area_size;
+
+	if (dev == NULL || log_header == NULL || buf == NULL || size == 0)
+		return 0;
+
+	log_area_size = EMMC_LOG_BUF_SIZE - dev->blkdev->blksz;
+	if (log_area_size == 0)
+		return 0;
+
+	if (size > log_area_size) {
+		buf += size - log_area_size;
+		size = log_area_size;
+	}
+
+	if (log_header->offset >= log_area_size)
+		log_header->offset = 0;
+
+	emmc_remain_buf_size = log_area_size - log_header->offset;
+	if (size > emmc_remain_buf_size) {
+		expdb_write(dev, part_end - EMMC_LOG_BUF_SIZE + log_header->offset,
+			    buf, emmc_remain_buf_size);
+		expdb_write(dev, part_end - EMMC_LOG_BUF_SIZE,
+			    buf + emmc_remain_buf_size, size - emmc_remain_buf_size);
+		log_header->offset = size - emmc_remain_buf_size;
+	} else {
+		expdb_write(dev, part_end - EMMC_LOG_BUF_SIZE + log_header->offset,
+			    buf, size);
+		log_header->offset += size;
+	}
+
+	return size;
+}
