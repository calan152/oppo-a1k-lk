+static void cmdline_append_avb_filtered(const char *cmdline, bool drop_root)
+{
+	static char filtered[AVB_CMDLINE_FILTERED_SIZE];
+	const char *p = cmdline;
+	uint32_t out = 0;
+	uint32_t removed = 0;
+	bool truncated = false;
+
+	if (cmdline == NULL || cmdline[0] == '\0')
+		return;
+
+	if (!drop_root) {
+		cmdline_append(cmdline);
+		return;
+	}
+
+	filtered[0] = '\0';
+	while (*p != '\0') {
+		const char *token;
+		size_t token_len;
+		uint32_t copy_len;
+
+		while (avb_cmdline_is_space(*p))
+			p++;
+
+		if (*p == '\0')
+			break;
+
+		token = p;
+		while (*p != '\0' && !avb_cmdline_is_space(*p))
+			p++;
+
+		token_len = (size_t)(p - token);
+		if (token_len == 0)
+			continue;
+
+		if (avb_cmdline_token_has_prefix(token, token_len, "root=")) {
+			removed++;
+			continue;
+		}
+
+		if (out != 0) {
+			if (out + 1 >= AVB_CMDLINE_FILTERED_SIZE) {
+				truncated = true;
+				break;
+			}
+			filtered[out++] = ' ';
+		}
+
+		copy_len = (uint32_t)token_len;
+		if (out + copy_len >= AVB_CMDLINE_FILTERED_SIZE) {
+			copy_len = AVB_CMDLINE_FILTERED_SIZE - out - 1;
+			truncated = true;
+		}
+
+		memcpy(filtered + out, token, copy_len);
+		out += copy_len;
+
+		if (truncated)
+			break;
+	}
+
+	filtered[out] = '\0';
+	pal_log_err("[avb] cmdline root filter: removed=%d truncated=%d\n",
+		removed, truncated);
+
+	if (out != 0)
+		cmdline_append(filtered);
+}
