+static void lcm_resume_power(void);
+static void lcm_init_power(void)/*esd recover will call it */
+{
+#ifdef BUILD_LK
+	oppo_lcm_init_power_cnt++;
+	LCM_LOGI("[OPPO_LCM_TRACE] %s enter cnt=%u\n",
+		 __func__, oppo_lcm_init_power_cnt);
+#else
+	LCM_LOGI("%s: enter\n", __func__);
+#endif
+	lcm_resume_power();
+	LCM_LOGI("%s: exit\n", __func__);
+}
+
+static void lcm_suspend_power(void)
+{
+#ifdef BUILD_LK
+	oppo_lcm_suspend_power_cnt++;
+	LCM_LOGI("[OPPO_LCM_TRACE] %s enter cnt=%u\n",
+		 __func__, oppo_lcm_suspend_power_cnt);
+#else
+	LCM_LOGI("%s: enter\n", __func__);
+#endif
+	lcm_set_pwr(0);
+	lcm_set_pwr_n(0);
+	LCM_LOGI("%s: exit\n", __func__);
+}
+static void lcm_resume_power(void)
+{
+	char buf[2]={0};
+#ifdef BUILD_LK
+	oppo_lcm_resume_power_cnt++;
+	LCM_LOGI("[OPPO_LCM_TRACE] %s enter cnt=%u\n",
+		 __func__, oppo_lcm_resume_power_cnt);
+#else
+	LCM_LOGI("%s: enter\n", __func__);
+#endif
+	lcm_set_pwr(1);
+	UDELAY(50);
+	//SM5109 reg[03] default value=0x03 NT50358CG reg[03]=0x33
+	//printk("read 0x00=%d,0x01=%d,lcd_bias_id=%d\n",buf[0],buf[1],lcd_bias_id);
+	LCM_LOGI("%s: lcd_bias_id=0x%02x\n", __func__, lcd_bias_id);
+	if(lcd_bias_id==0x03){
+		sm5109_write_bytes(0x00,0x34);//6v avdd SM5109
+		sm5109_write_bytes(0x01,0x14);//-6v avee
+	}else{
+		sm5109_write_bytes(0x00,0x14);//6v avdd NT50358CG
+		sm5109_write_bytes(0x01,0x14);//-6v avee
+	}
+	MDELAY(2);//powertiming
+	lcm_set_pwr_n(1);
+	sm5109_read_bytes(0x00,&buf[0]);
+	sm5109_read_bytes(0x01,&buf[1]);
+
+	LCM_LOGI("%s: read 0x00=%d,0x01=%d exit\n", __func__,buf[0],buf[1]);
+}
+
+#ifndef BUILD_LK
+extern unsigned int esd_recovery_state;
+#endif
+static void lcm_init_lcm(void)
+{
+#ifdef BUILD_LK
+	oppo_lcm_init_cnt++;
+	LCM_LOGI("[OPPO_LCM_TRACE] %s enter cnt=%u esd=%u\n",
+		 __func__, oppo_lcm_init_cnt, esd_recovery_state);
+#endif
+	MDELAY(6);
+	if(esd_recovery_state){
+		SET_RESET_PIN(1);
+		MDELAY(10);
+		SET_RESET_PIN(0);
+		MDELAY(10);
+		SET_RESET_PIN(1);
+		MDELAY(120);
+	}else{
+		LCM_LOGI("%s: reset normal 1-2-0-2-1-10\n", __func__);
+		SET_RESET_PIN(1);
+		MDELAY(2);
+		SET_RESET_PIN(0);
+		MDELAY(2);
+		SET_RESET_PIN(1);
+		MDELAY(10);
+	}
+
+	push_table(NULL, init_setting, sizeof(init_setting) / sizeof(struct LCM_setting_table), 1);
+	LCM_LOGI("[OPPO_LCM_TRACE] %s exit cnt=%u\n",
+		 __func__, oppo_lcm_init_cnt);
+}
