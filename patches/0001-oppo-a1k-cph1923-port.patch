+else
+MEMBASE := 0x48000000 # SDRAM
+endif
+
+ifeq ($(MTK_MLC_NAND_SUPPORT), yes)
+DEFINES += MTK_MLC_NAND_SUPPORT
+MEMSIZE := 0x00900000 # 9MB
+else ifeq ($(MTK_TLC_NAND_SUPPORT), yes)
+DEFINES += MTK_TLC_NAND_SUPPORT
