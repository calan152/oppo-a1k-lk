+static unsigned int oppo_early_log_pos;
+static unsigned int oppo_early_log_init_done;
+static unsigned int oppo_stock_lk_log_store_enable;
+
+static void oppo_early_log_char(char c)
+{
+	if (!oppo_early_log_init_done)
+		oppo_early_log_init_done = 1;
+
+	if (oppo_early_log_pos >= OPPO_EARLY_LOG_SIZE - 1)
+		return;
+
+	oppo_early_log_buf[oppo_early_log_pos++] = c;
+	oppo_early_log_buf[oppo_early_log_pos] = 0;
+}
+
+void oppo_early_log_puts(const char *s)
+{
+	if (!s)
+		return;
+
+	while (*s)
+		oppo_early_log_char(*s++);
+}
+
+const char *oppo_early_log_buf_get(unsigned int *len)
+{
+	if (len)
+		*len = oppo_early_log_pos;
+
+	return oppo_early_log_buf;
+}
+
+void oppo_enable_stock_lk_log_store(void)
+{
+	oppo_stock_lk_log_store_enable = 1;
+}
