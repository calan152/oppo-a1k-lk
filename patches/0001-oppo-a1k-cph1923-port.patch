+	LCM_LOGI("%s: enter\n", __func__);
+#endif
+	push_table(NULL, lcm_suspend_setting, sizeof(lcm_suspend_setting) / sizeof(struct LCM_setting_table), 1);
+	SET_RESET_PIN(0);
+	MDELAY(2);/*for power timing*/
+	LCM_LOGI("%s: exit\n", __func__);
+}
+
+static void lcm_resume(void)
+{
+#ifdef BUILD_LK
+	oppo_lcm_resume_cnt++;
+	LCM_LOGI("[OPPO_LCM_TRACE] %s enter cnt=%u\n",
+		 __func__, oppo_lcm_resume_cnt);
+#endif
+	lcm_init_lcm();
+	LCM_LOGI("%s: exit\n", __func__);
+}
+
+#ifdef BUILD_LK
+static int lcm_read_id_gpio(unsigned int gpio)
+{
+	unsigned int pin = LK_GPIO_PIN(gpio);
+	int old_mode = mt_get_gpio_mode(pin);
+	int old_dir = mt_get_gpio_dir(pin);
+	int old_pullen = mt_get_gpio_pull_enable(pin);
+	int old_pull = mt_get_gpio_pull_select(pin);
+	int value;
+
+	mt_set_gpio_mode(pin, GPIO_MODE_00);
+	mt_set_gpio_dir(pin, GPIO_DIR_IN);
+	mt_set_gpio_pull_enable(pin, GPIO_PULL_ENABLE);
+	mt_set_gpio_pull_select(pin, GPIO_PULL_DOWN);
+	MDELAY(1);
+	value = mt_get_gpio_in(pin);
+
+	if (old_pull >= 0)
+		mt_set_gpio_pull_select(pin, old_pull);
+	if (old_pullen >= 0)
+		mt_set_gpio_pull_enable(pin, old_pullen);
+	if (old_dir >= 0)
+		mt_set_gpio_dir(pin, old_dir);
+	if (old_mode >= 0)
+		mt_set_gpio_mode(pin, old_mode);
+
+	return value;
+}
+#endif
+
+static unsigned int lcm_compare_id(void)
+{
+#ifdef BUILD_LK
+	int gpio_id_0;
+	int gpio_id_1;
+	int gpio_id_2;
+
+	LCM_LOGI("%s: enter\n", __func__);
+	gpio_id_0 = lcm_read_id_gpio(GPIO_LCM_ID_0);
+	gpio_id_1 = lcm_read_id_gpio(GPIO_LCM_ID_1);
+	gpio_id_2 = lcm_read_id_gpio(GPIO_LCM_ID_2);
+
+	LCM_LOGI("[LCM]%s,module gpio_id_0 = %d,gpio_id_1 = %d, gpio_id_2 = %d\n",
+		__func__, gpio_id_0, gpio_id_1, gpio_id_2);
+	return gpio_id_0 == 0 && gpio_id_1 == 0 && gpio_id_2 == 0;
+#else
+	LCM_LOGI("%s: enter\n", __func__);
+	return 1;
+#endif
+}
+
+static void lcm_setbacklight_cmdq(void *handle, unsigned int level)//255 0xf f //0x0f 0xf0
+{
+	bl_level[1].para_list[0]=(level&0x7ff)>>7;/*get hight 4bit*/
+	bl_level[1].para_list[1]=(level<<1)&0xfe;/*get low 7bit*/
+	push_table(handle, bl_level,
+		sizeof(bl_level) / sizeof(struct LCM_setting_table), 1);
+//	esd_recovery_backlight_level=level;
+}
+
+static void lcm_setbacklight(unsigned int level)
+{
+#ifdef BUILD_LK
+	oppo_lcm_backlight_cnt++;
+	oppo_lcm_last_backlight = level;
+	LCM_LOGI("[OPPO_LCM_TRACE] %s level=%u cnt=%u\n",
+		 __func__, level, oppo_lcm_backlight_cnt);
+#else
+	LCM_LOGI("%s,ili9881c backlight: level = %d\n", __func__, level);
+#endif
+	lcm_setbacklight_cmdq(NULL, level);
+	LCM_LOGI("%s: exit\n", __func__);
+}
+
+static void lcm_set_cabc_mode_cmdq(void *handle, unsigned int level)
+{
+	LCM_LOGI("%s [lcd] cabc_mode is %d\n", __func__, level);
+
+	if (1==level){
+		push_table(handle, lcm_cabc_enter_setting1, sizeof(lcm_cabc_enter_setting1) / sizeof(struct LCM_setting_table), 1);
+	}else if(2==level){
+		push_table(handle, lcm_cabc_enter_setting2, sizeof(lcm_cabc_enter_setting2) / sizeof(struct LCM_setting_table), 1);
+	}else if(3==level){
+		push_table(handle, lcm_cabc_enter_setting3, sizeof(lcm_cabc_enter_setting3) / sizeof(struct LCM_setting_table), 1);
+	} else {
+		push_table(handle, lcm_cabc_exit_setting, sizeof(lcm_cabc_exit_setting) / sizeof(struct LCM_setting_table), 1);
+	}
+}
