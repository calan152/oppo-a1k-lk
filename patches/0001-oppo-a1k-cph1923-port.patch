+#ifdef OPPO_EARLY_LOG_EXPDB_FLUSH
+#define OPPO_EARLY_LOG_EXPDB_PART       "expdb"
+#ifndef OPPO_EXPDB_LOG_AREA_SIZE
+#define OPPO_EXPDB_LOG_AREA_SIZE        0x200000
+#endif
+#define OPPO_EARLY_LOG_STOCK_AREA_SIZE  OPPO_EXPDB_LOG_AREA_SIZE
+#define OPPO_EARLY_LOG_STOCK_MAX_SAVE   0x400000
+#define OPPO_EARLY_LOG_EMMC_BLOCK_SIZE  512
+
+static void oppo_stock_ring_write_buffer(const char *label,
+					 const char *buf,
+					 unsigned int len)
+{
+	static unsigned char emmc_header_block[OPPO_EARLY_LOG_EMMC_BLOCK_SIZE] __attribute__((aligned(512)));
+	struct log_emmc_header *log_header = (struct log_emmc_header *)emmc_header_block;
+	const char *copy_buf;
+	unsigned int copy_len;
+	unsigned int emmc_remain;
+	u64 ring_start;
+	u64 header_off;
+	u64 part_size;
+	ssize_t read_ret;
+	ssize_t write_ret1 = 0;
+	ssize_t write_ret2 = 0;
+	ssize_t header_ret;
+
+	if (buf == NULL || len == 0)
+		return;
+
+	part_size = partition_get_size_by_name(OPPO_EARLY_LOG_EXPDB_PART);
+	if (part_size < OPPO_EARLY_LOG_STOCK_AREA_SIZE) {
+		dprintf(CRITICAL,
+			"[OPPO_EARLY_LOG] %s too small: size=0x%llx stock_area=0x%x\n",
+			OPPO_EARLY_LOG_EXPDB_PART,
+			part_size,
+			OPPO_EARLY_LOG_STOCK_AREA_SIZE);
+		return;
+	}
+
+	ring_start = part_size - OPPO_EARLY_LOG_STOCK_AREA_SIZE;
+	header_off = part_size - OPPO_EARLY_LOG_EMMC_BLOCK_SIZE;
+	read_ret = partition_read(OPPO_EARLY_LOG_EXPDB_PART,
+				  header_off,
+				  emmc_header_block,
+				  sizeof(emmc_header_block));
+	if (read_ret != sizeof(emmc_header_block) ||
+	    log_header->sig != LOG_EMMC_SIG ||
+	    log_header->offset >= OPPO_EARLY_LOG_STOCK_AREA_SIZE - OPPO_EARLY_LOG_EMMC_BLOCK_SIZE) {
+		memset(emmc_header_block, 0, sizeof(emmc_header_block));
+		log_header->sig = LOG_EMMC_SIG;
+		log_header->offset = 0;
+	}
+
+	copy_buf = buf;
+	copy_len = len;
+	if (copy_len > OPPO_EARLY_LOG_STOCK_MAX_SAVE) {
+		copy_buf += copy_len - OPPO_EARLY_LOG_STOCK_MAX_SAVE;
+		copy_len = OPPO_EARLY_LOG_STOCK_MAX_SAVE;
+	}
+
+	emmc_remain = OPPO_EARLY_LOG_STOCK_AREA_SIZE -
+		      OPPO_EARLY_LOG_EMMC_BLOCK_SIZE -
+		      log_header->offset;
+	if (copy_len > emmc_remain) {
+		write_ret1 = partition_write(OPPO_EARLY_LOG_EXPDB_PART,
+					     ring_start + log_header->offset,
+					     (void *)copy_buf,
+					     emmc_remain);
+		write_ret2 = partition_write(OPPO_EARLY_LOG_EXPDB_PART,
+					     ring_start,
+					     (void *)(copy_buf + emmc_remain),
+					     copy_len - emmc_remain);
+		log_header->offset = copy_len - emmc_remain;
+	} else {
+		write_ret1 = partition_write(OPPO_EARLY_LOG_EXPDB_PART,
+					     ring_start + log_header->offset,
+					     (void *)copy_buf,
+					     copy_len);
+		log_header->offset += copy_len;
+	}
+
+	header_ret = partition_write(OPPO_EARLY_LOG_EXPDB_PART,
+				     header_off,
+				     emmc_header_block,
+				     sizeof(emmc_header_block));
+#ifdef OPPO_EARLY_LOG_VERBOSE
+	dprintf(CRITICAL,
+		"[OPPO_EARLY_LOG] direct fallback %s label=%s read=%ld write1=%ld write2=%ld header=%ld ring=0x%llx header=0x%llx len=%u copy=%u next=0x%x\n",
+		OPPO_EARLY_LOG_EXPDB_PART,
+		label ? label : "unknown",
+		read_ret,
+		write_ret1,
+		write_ret2,
+		header_ret,
+		ring_start,
+		header_off,
+		len,
+		copy_len,
+		log_header->offset);
+#else
+	(void)label;
+	(void)read_ret;
+	(void)write_ret1;
+	(void)write_ret2;
+	(void)header_ret;
+	(void)ring_start;
+	(void)header_off;
+#endif
+}
+
+static void oppo_flush_early_log_direct_to_stock_ring(const char *stage)
+{
+	static char status[1024];
+	struct lk_log_store_debug_info info;
+	const char *log_buf;
+	unsigned int log_len;
+	unsigned int status_len;
+
+	memset(&info, 0, sizeof(info));
+	lk_log_store_debug_info_get(&info);
+
+	status_len = snprintf(status, sizeof(status),
+		"OPPO_EARLY_STATUS_V1\n"
+		"stage=%s\n"
+		"stock_ready=%u\n"
+		"status=0x%08x\n"
+		"rc_sram=0x%08x\n"
+		"rc_sram_size=0x%08x\n"
+		"rc_meminfo_off=0x%08x\n"
+		"dbg_sram_addr=0x%08x\n"
+		"dbg_sram_size=0x%08x\n"
+		"sram_sig=0x%08x\n"
+		"dram_sig=0x%08x\n"
+		"dram_flag=0x%08x\n"
+		"dram_buf_addr=0x%08x\n"
+		"dram_buf_size=0x%08x\n"
+		"log_sig=0x%08x\n"
+		"log_buff_size=0x%08x\n"
+		"log_off_pl=0x%08x\n"
+		"log_sz_pl=0x%08x\n"
+		"log_sz_lk=0x%08x\n",
+		stage ? stage : "unknown",
+		lk_log_store_ready() ? 1 : 0,
+		info.status,
+		g_boot_arg ? g_boot_arg->ram_console_sram_addr : 0,
+		g_boot_arg ? g_boot_arg->ram_console_sram_size : 0,
+		g_boot_arg ? g_boot_arg->ram_console_memory_info_offset : 0,
+		info.sram_addr,
+		info.sram_size,
+		info.sram_sig,
+		info.dram_sig,
+		info.dram_flag,
+		info.dram_buf_addr,
+		info.dram_buf_size,
+		info.log_sig,
+		info.log_buff_size,
+		info.log_off_pl,
+		info.log_sz_pl,
+		info.log_sz_lk);
+
+	if (status_len >= sizeof(status))
+		status_len = sizeof(status) - 1;
+
+	oppo_stock_ring_write_buffer("status", status, status_len);
+
+	oppo_early_log_puts("[OPPO_EARLY] direct stock-ring fallback stage=");
+	oppo_early_log_puts(stage ? stage : "unknown");
+	oppo_early_log_puts("\n");
+
+	log_buf = oppo_early_log_buf_get(&log_len);
+	oppo_stock_ring_write_buffer("early", log_buf, log_len);
+}
+
+static void oppo_replay_early_log_to_stock_log_store(const char *stage)
+{
+#ifdef OPPO_EARLY_LOG_DIRECT_FALLBACK_ONLY
+	oppo_early_log_puts("[OPPO_EARLY] direct expdb fallback only stage=");
+	oppo_early_log_puts(stage ? stage : "unknown");
+	oppo_early_log_puts("\n");
+	oppo_flush_early_log_direct_to_stock_ring(stage);
+#else
+	const char *log_buf;
+	unsigned int log_len;
+	unsigned int i;
+
+	log_buf = oppo_early_log_buf_get(&log_len);
+
+	for (i = 0; i < log_len; i++)
+		lk_log_store(log_buf[i]);
+
+	if (!lk_log_store_ready()) {
+		oppo_early_log_puts("[OPPO_EARLY] stock lk_log_store NOT READY, using direct fallback\n");
+		dprintf(CRITICAL,
+			"[OPPO_EARLY_LOG] stock lk_log_store is not ready, replay len=%u stage=%s\n",
+			log_len,
+			stage ? stage : "unknown");
+		oppo_flush_early_log_direct_to_stock_ring(stage);
+		return;
+	}
+
+	oppo_enable_stock_lk_log_store();
+#ifdef OPPO_EARLY_LOG_VERBOSE
+	dprintf(CRITICAL,
+		"[OPPO_EARLY_LOG] replayed %u bytes to stock lk_log_store, save_pllk_log stage=%s\n",
+		log_len,
+		stage ? stage : "unknown");
+#endif
+	save_pllk_log();
+#endif
+}
+#endif
 
