+static int oppo_dt_strnlen(const char *s, int max)
+{
+	int i;
+
+	for (i = 0; i < max; i++) {
+		if (s[i] == '\0')
+			break;
+	}
+
+	return i;
+}
+
+static int oppo_dt_stringlist_count(const char *list, int len)
+{
+	int count = 0;
+	int pos = 0;
+
+	while (list && pos < len && list[pos] != '\0') {
+		int slen = oppo_dt_strnlen(list + pos, len - pos);
+
+		count++;
+		pos += slen + 1;
+	}
+
+	return count;
+}
+
+static int oppo_dt_stringlist_index(const char *list, int len,
+				    const char *name)
+{
+	int pos = 0;
+	int idx = 0;
+	int name_len = strlen(name);
+
+	while (list && pos < len && list[pos] != '\0') {
+		int slen = oppo_dt_strnlen(list + pos, len - pos);
+
+		if (slen == name_len && memcmp(list + pos, name, name_len) == 0)
+			return idx;
+
+		pos += slen + 1;
+		idx++;
+	}
+
+	return -1;
+}
+
+static int oppo_dt_stringlist_has_prefix(const char *list, int len,
+					 const char *prefix)
+{
+	int pos = 0;
+	int prefix_len = strlen(prefix);
+
+	while (list && pos < len && list[pos] != '\0') {
+		int slen = oppo_dt_strnlen(list + pos, len - pos);
+
+		if (slen >= prefix_len &&
+		    memcmp(list + pos, prefix, prefix_len) == 0)
+			return 1;
+
+		pos += slen + 1;
+	}
+
+	return 0;
+}
+
+static int oppo_fdt_find_lcm_node(void *fdt)
+{
+	int offset;
+
+	offset = fdt_path_offset(fdt, "/lcm");
+	if (offset >= 0)
+		return offset;
+
+	return fdt_node_offset_by_compatible(fdt, -1, "mediatek,lcm_mode");
+}
+
+static int oppo_fdt_get_pinctrl_state_prop(void *fdt, int node,
+					   const char *state,
+					   const void **data, int *data_len)
+{
+	char prop_name[16];
+	const char *names;
+	int names_len;
+	int idx;
+
+	names = fdt_getprop(fdt, node, "pinctrl-names", &names_len);
+	if (!names || names_len <= 0)
+		return -FDT_ERR_NOTFOUND;
+
+	idx = oppo_dt_stringlist_index(names, names_len, state);
+	if (idx < 0)
+		return -FDT_ERR_NOTFOUND;
+
+	snprintf(prop_name, sizeof(prop_name), "pinctrl-%d", idx);
+	*data = fdt_getprop(fdt, node, prop_name, data_len);
+	if (!*data || *data_len <= 0)
+		return -FDT_ERR_NOTFOUND;
+
+	return 0;
+}
+
+static int oppo_fdt_append_lcm_pinctrl(void *fdt, int lcm_node,
+				       char *names, int *names_len,
+				       int *next_idx, const char *state,
+				       const void *data, int data_len)
+{
+	char prop_name[16];
+	int state_len = strlen(state) + 1;
+	int ret;
+
+	if (oppo_dt_stringlist_index(names, *names_len, state) >= 0)
+		return 0;
+
+	if (*names_len + state_len > OPPO_LCM_PINCTRL_NAMES_MAX)
+		return -FDT_ERR_NOSPACE;
+
+	snprintf(prop_name, sizeof(prop_name), "pinctrl-%d", *next_idx);
+	ret = fdt_setprop(fdt, lcm_node, prop_name, data, data_len);
+	if (ret)
+		return ret;
+
+	memcpy(names + *names_len, state, state_len);
+	*names_len += state_len;
+	(*next_idx)++;
+
+	return 0;
+}
+
+static int oppo_fdt_find_node_with_pinctrl_state(void *fdt, const char *state)
+{
+	int node = -1;
+
+	while ((node = fdt_next_node(fdt, node, NULL)) >= 0) {
+		const char *names;
+		int names_len;
+
+		names = fdt_getprop(fdt, node, "pinctrl-names", &names_len);
+		if (!names || names_len <= 0)
+			continue;
+
+		if (oppo_dt_stringlist_index(names, names_len, state) >= 0)
+			return node;
+	}
+
+	return -FDT_ERR_NOTFOUND;
+}
+
+static int oppo_fdt_copy_lcm_pinctrl(void *fdt, int lcm_node,
+				     char *names, int *names_len, int *next_idx,
+				     const char *src_state, const char *dst_state,
+				     int preferred_src)
+{
+	const void *prop;
+	int prop_len;
+	char prop_buf[OPPO_LCM_PINCTRL_PROP_MAX];
+	int src_node = preferred_src;
+	int ret;
+
+	if (src_node < 0 ||
+	    oppo_fdt_get_pinctrl_state_prop(fdt, src_node, src_state,
+					     &prop, &prop_len)) {
+		src_node = oppo_fdt_find_node_with_pinctrl_state(fdt, src_state);
+		if (src_node < 0) {
+			pal_log_err("[OPPO_LCM_DT] missing pinctrl state %s\n",
+				    src_state);
+			return 0;
+		}
+	}
+
+	ret = oppo_fdt_get_pinctrl_state_prop(fdt, src_node, src_state,
+					      &prop, &prop_len);
+	if (ret)
+		return ret;
+
+	if (prop_len > OPPO_LCM_PINCTRL_PROP_MAX)
+		return -FDT_ERR_NOSPACE;
+
+	memcpy(prop_buf, prop, prop_len);
+	return oppo_fdt_append_lcm_pinctrl(fdt, lcm_node, names, names_len,
+					next_idx, dst_state, prop_buf, prop_len);
+}
+
+static void oppo_fdt_disable_lcm_esd(void *fdt)
+{
+	int node = -1;
+	int patched = 0;
+
+	while ((node = fdt_next_node(fdt, node, NULL)) >= 0) {
+		const char *compat;
+		int compat_len;
+
+		compat = fdt_getprop(fdt, node, "compatible", &compat_len);
+		if (!compat || compat_len <= 0)
+			continue;
+
+		if (!oppo_dt_stringlist_has_prefix(compat, compat_len,
+						   "mediatek,lcm_params-"))
+			continue;
+
+		fdt_setprop_cell(fdt, node,
+			"lcm_params-dsi-customization_esd_check_enable", 0);
+		fdt_setprop_cell(fdt, node,
+			"lcm_params-dsi-esd_check_enable", 0);
+		fdt_setprop_cell(fdt, node,
+			"lcm_params-dsi-lcm_int_te_monitor", 0);
+		fdt_setprop_cell(fdt, node,
+			"lcm_params-dsi-lcm_ext_te_monitor", 0);
+		patched++;
+	}
+
+	pal_log_err("[OPPO_LCM_DT] disabled early lcm esd nodes=%d\n",
+		    patched);
+}
+
+static int oppo_fix_lcm_gpio_dt(void *fdt)
+{
+	int lcm_node;
+	const char *lcm_names;
+	int lcm_names_len;
+	char new_names[OPPO_LCM_PINCTRL_NAMES_MAX];
+	int new_names_len;
+	int next_idx;
+	int ret;
+
+	lcm_node = oppo_fdt_find_lcm_node(fdt);
+	if (lcm_node < 0) {
+		int root = fdt_path_offset(fdt, "/");
+
+		if (root < 0)
+			return root;
+
+		lcm_node = fdt_add_subnode(fdt, root, "lcm");
+		if (lcm_node < 0) {
+			pal_log_err("[OPPO_LCM_DT] cannot create /lcm ret=%d\n",
+				    lcm_node);
+			return lcm_node;
+		}
+	}
+
+	ret = fdt_setprop_string(fdt, lcm_node, "compatible",
+				 "mediatek,lcm_mode");
+	if (ret)
+		return ret;
+
+	ret = fdt_setprop_string(fdt, lcm_node, "status", "okay");
+	if (ret)
+		return ret;
+
+	lcm_names = fdt_getprop(fdt, lcm_node, "pinctrl-names",
+				&lcm_names_len);
+	if (!lcm_names || lcm_names_len < 0)
+		lcm_names_len = 0;
+
+	if (lcm_names_len > OPPO_LCM_PINCTRL_NAMES_MAX)
+		return -FDT_ERR_NOSPACE;
+
+	memset(new_names, 0, sizeof(new_names));
+	if (lcm_names_len > 0)
+		memcpy(new_names, lcm_names, lcm_names_len);
+	new_names_len = lcm_names_len;
+	next_idx = oppo_dt_stringlist_count(new_names, new_names_len);
+
+	ret = oppo_fdt_copy_lcm_pinctrl(fdt, lcm_node, new_names,
+					 &new_names_len, &next_idx,
+					 "state_bais_P_output0",
+					 "state_bais_P_output0", lcm_node);
+	if (ret)
+		return ret;
+
+	ret = oppo_fdt_copy_lcm_pinctrl(fdt, lcm_node, new_names,
+					 &new_names_len, &next_idx,
+					 "state_bais_P_output1",
+					 "state_bais_P_output1", lcm_node);
+	if (ret)
+		return ret;
+
+	ret = oppo_fdt_copy_lcm_pinctrl(fdt, lcm_node, new_names,
+					 &new_names_len, &next_idx,
+					 "state_bais_N_output0",
+					 "state_bais_N_output0", lcm_node);
+	if (ret)
+		return ret;
+
+	ret = oppo_fdt_copy_lcm_pinctrl(fdt, lcm_node, new_names,
+					 &new_names_len, &next_idx,
+					 "state_bais_N_output1",
+					 "state_bais_N_output1", lcm_node);
+	if (ret)
+		return ret;
+
+	ret = fdt_setprop(fdt, lcm_node, "pinctrl-names", new_names,
+			  new_names_len);
+	if (ret)
+		return ret;
+
+	oppo_fdt_disable_lcm_esd(fdt);
+
+	pal_log_err("[OPPO_LCM_DT] /lcm pinctrl handoff fixed, states=%d\n",
+		    next_idx);
+	return 0;
+}
