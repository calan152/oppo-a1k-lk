+static int sm5109_write_bytes(unsigned char addr, unsigned char value)
+{
+	kal_uint8 write_data[2];
+	int ret;
+
+	write_data[0] = addr;
+	write_data[1] = value;
+
+	sm5109_i2c.id = SM5109_I2C_ID;
+	sm5109_i2c.addr = (SM5109_SLAVE_ADDR_WRITE >> 1);
+	sm5109_i2c.mode = ST_MODE;
+	sm5109_i2c.speed = 100;
+
+	ret = i2c_write(&sm5109_i2c, write_data, 2);
+	if (ret != I2C_OK)
+		LCM_LOGI("%s: I2CW[0x%02x]=0x%02x failed, ret=%d\n",
+			__func__, addr, value, ret);
+	else
+		LCM_LOGI("%s: I2CW[0x%02x]=0x%02x ok\n",
+			__func__, addr, value);
+
+	return ret;
+}
+
+static int sm5109_read_bytes(u8 addr, void *data)
