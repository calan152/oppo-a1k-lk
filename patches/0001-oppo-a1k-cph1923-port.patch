+	case RECOVERY_BOOT:
+		return "recovery";
+	case META_BOOT:
+		return "meta";
+	case FACTORY_BOOT:
+		return "factory";
+	case ADVMETA_BOOT:
+		return "advanced_meta";
+	case ATE_FACTORY_BOOT:
+		return "ate_factory";
+	case FASTBOOT:
+		return "fastboot";
+	default:
+		return "normal";
+	}
+}
+
+void target_append_oppo_bootargs(BOOTMODE boot_mode)
+{
+	char tmpbuf[64];
+
+	cmdline_append("emmc_max_chunck_size=4194304");
+
+	cmdline_append("oppo_custom_project=" OPPO_CUSTOM_PROJECT);
+	snprintf(tmpbuf, sizeof(tmpbuf), "oppo_boot_mode=%d", boot_mode);
+	cmdline_append(tmpbuf);
+
+	if (boot_mode != NORMAL_BOOT) {
+		snprintf(tmpbuf, sizeof(tmpbuf), "androidboot.oppo_boot_mode=%d", boot_mode);
+		cmdline_append(tmpbuf);
+
+		snprintf(tmpbuf, sizeof(tmpbuf), "androidboot.mode=%s",
+			 oppo_android_boot_mode_name(boot_mode));
+		cmdline_append(tmpbuf);
+
+		snprintf(tmpbuf, sizeof(tmpbuf), "boot_mode=%d", boot_mode);
+		cmdline_append(tmpbuf);
+	}
+
+	cmdline_append("is_lm3697=1");
+	cmdline_append("short_c_battery_status=0");
+	cmdline_append("short_c_switch_status=0");
+	cmdline_append("short_c_feature_sw_status=1");
+	cmdline_append("short_c_feature_hw_status=0");
+	cmdline_append("board_id=688");
+	cmdline_append("lcd_bias_id=51");
+	cmdline_append("single double cam=2");
+}
diff --git a/target/oppo6762_18540/power_off.c b/target/oppo6762_18540/power_off.c
new file mode 100644
index 0000000000000000000000000000000000000000..e74e3c072e60bc124b783f421de77a66cb40c8ef
--- /dev/null
+++ b/target/oppo6762_18540/power_off.c
@@ -0,0 +1,29 @@
+//#include <common.h>
+//#include <asm/arch/mt65xx.h>
+#include <debug.h>
+#include <platform/mt_typedefs.h>
+#include <platform/mt_rtc.h>
+#include <platform/mtk_wdt.h>
+
+extern kal_bool pmic_chrdet_status(void);
+
+#ifndef NO_POWER_OFF
+void mt6575_power_off(void)
+{
+	int count = 0;
+	dprintf(CRITICAL, "mt_power_off\n");
+
+	/* pull PWRBB low */
+	rtc_bbpu_power_down();
+
+	while (1) {
+		mdelay(100);
+		dprintf(CRITICAL, "mt_power_off : check charger\n");
+		if (pmic_chrdet_status() == KAL_TRUE || count > 10) {
+			mtk_arch_reset(0);
+			break;
+		}
+		count++;
+	}
+}
+#endif
