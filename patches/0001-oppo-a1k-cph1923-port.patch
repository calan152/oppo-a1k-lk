+MTK_CHARGER_INTERFACE := yes
+MTK_LCM_PHYSICAL_ROTATION = 0
+LCM_WIDTH = 720
+LCM_HEIGHT = 1560
+CUSTOM_LK_LCM="ili9881c_hd_dsi_vdo_txd_boe_zal1890"
+# OPPO stock LK reserves an extra 0x40000 bytes for full-width round-corner
+# handoff. The panel driver below provides LK-compatible round_corner_params.
+DEFINES += MTK_ROUND_CORNER_SUPPORT
+#nt35595_fhd_dsi_cmd_truly_nt50358 = yes
+#FASTBOOT_USE_G_ORIGINAL_PROTOCOL = yes
+MTK_SECURITY_SW_SUPPORT = yes
+MTK_VERIFIED_BOOT_SUPPORT = yes
+MTK_SEC_FASTBOOT_UNLOCK_SUPPORT = yes
+# Keep LK write-protect enabled, but do not lock Android data-bearing
+# partitions in this OPPO bring-up build.
+DEFINES += OPPO_WP_BOOTCHAIN_ONLY
+SPM_FW_USE_PARTITION = yes
+BOOT_LOGO := hd720
+DEFINES += OPPO_LK_LOGO_DB_IN_SCRATCH
+DEBUG := 2
+#DEFINES += WITH_DEBUG_DCC=1
+DEFINES += WITH_DEBUG_UART=1
+# OPPO debug-only stops are disabled for normal UART/WDT bring-up.
+# DEFINES += OPPO_LK_ALIVE_STOP
+# DEFINES += OPPO_LK_WDT_FULL_OFF
+# Bring-up probes below are useful when UART/logstore is broken, but they
+# pollute normal LK UART/expdb logs.
+# DEFINES += OPPO_CRT0_RESERVE_MARKER
+# DEFINES += OPPO_EARLY_UART_RAW_PROBE
+DEFINES += OPPO_EARLY_LOG_EXPDB_FLUSH
+DEFINES += OPPO_EXPDB_LOG_AREA_SIZE=0x1400000
+DEFINES += OPPO_UART_FORCE_BUS_CLOCK
+# Bring-up watchdog: convert the LK WDT from IRQ mode to reset mode right
+# before kernel handoff, so a kernel-side hang still produces a fresh expdb.
+DEFINES += OPPO_KERNEL_HANDOFF_WDT
+DEFINES += OPPO_KERNEL_HANDOFF_WDT_SEC=20
+# Match stock OPPO unlocked normal boot root selection: boot uses
+# "ro rootwait init=/init", recovery/meta ramdisk paths use root=/dev/ram,
+# and AVB appends the raw root=PARTUUID layer.
+DEFINES += OPPO_STOCK_RAMDISK_ROOT_CMDLINE
+# Keep LK/ATF AVB verification intact, but do not expose vbmeta measurement
+# totals to Android userspace.  Our verified chain includes recovery vbmeta,
+# while fs_mgr later opens only the boot-time chain and reports
+# "total vbmeta size mismatch".
+DEFINES += OPPO_HIDE_AVB_VBMETA_MEASUREMENTS
+# Optional diagnostic mode: force AVB cmdline down to a raw PARTUUID root.
+# DEFINES += OPPO_AVB_ROOT_PARTUUID_ONLY
+# Unlocked OPPO boot keeps orange/raw root. Do not force the locked
+# dm-verity path from a stock locked log.
+# DEFINES += OPPO_AVB_STRICT_FIRST_FOR_DM
+# Keep normal boot cmdline close to stock.  The diagnostic bundle below adds
+# earlycon/loglevel/initcall_debug/panic/ramoops tokens that are not present in
+# stock OPPO LK normal boot logs.
+# DEFINES += OPPO_STOCK_KERNEL_DIAG_CMDLINE
+# Keep the final kernel cmdline quiet: strip debug-only tokens if a test
+# boot.img brings them in its own header.
+DEFINES += OPPO_DROP_BOOTIMG_DIAG_CMDLINE
+# The current lk_main_dtb also carries a few debug-only tokens in
+# /chosen/bootargs, so filter the same diagnostic set before AVB/appended
+# OPPO parameters are added.
+DEFINES += OPPO_DROP_DTB_DIAG_CMDLINE
+# Normal boot must not inherit stale META/FACTORY keys from boot images or
+# previous cmdline layers.  Keep one value per key before handing FDT to Linux.
+DEFINES += OPPO_DEDUP_NORMAL_CMDLINE
+# Match stock OPPO LK CCCI/MD mblock placement.  The weak MT6765 defaults keep
+# MD below 0xa0000000, while stock CPH1923 loads md1rom at 0xae000000 and keeps
+# ccci_tag_mem just below the ATF ramdump window.
+DEFINES += OPPO_STOCK_MD_HIGH_MBLOCK
+# Rebuild normal cmdline in stock unlocked order after all dynamic values
+# are known, while preserving /chosen/bootargs as the first layer.
+DEFINES += OPPO_FORCE_MINIMAL_NORMAL_CMDLINE
+# Stock uses the recovery key as the boot-menu key on this board.  Do not
+# treat that same key as a direct recovery request.
+DEFINES += OPPO_RECOVERY_KEY_AS_BOOT_MENU
+# Keep panic/hang diagnostics from the boot image cmdline.  Removing them made
+# kernel hangs silent, with no reboot and no fresh expdb.
+# DEFINES += OPPO_REMOVE_PANIC_CMDLINE
+# Exact stock unlocked normal log passes androidboot.atm=enable.
+DEFINES += OPPO_FORCE_ATM_ENABLE
+DEFINES += OPPO_SKIP_BOOT_DEVICES_CMDLINE
+# Stock unlocked normal boot passes androidboot.bootreason=reboot even after
+# stale kernel panic/hang records.  Recovery/META keep their real reason.
+DEFINES += OPPO_NORMAL_BOOTREASON_NO_STALE_PANIC
+# Stock OPPO LK sends only three Root-of-Trust SMC packets.  The AVB20 six-call
+# variant returns 0xffffffff on this ATF after the legacy payload.
+DEFINES += OPPO_STOCK_ROT_3CALL
+DEFINES += SERIAL_NUM_FROM_BARCODE
+# Keep the stock display bring-up order: apply GPIO defaults from the
+# overlayed DTB, then run leds_init()/mt6370_bled_probe().
+# DEFINES += OPPO_SKIP_LATE_GPIO_DEFAULT
+# DEFINES += OPPO_SKIP_LEDS_INIT
+# Keep the safe ATF/log init path, but skip the full mini dump reader.  On
+# this target the full reader resets after "kedump: address:0x48b00000".
+DEFINES += OPPO_KEDUMP_ATF_ONLY
+# DEFINES += OPPO_SKIP_KEDUMP_MINI
+DEFINES += OPPO_KEDUMP_CONTINUE_AFTER_SAVE
+DEFINES += OPPO_FORCE_LCM_CONNECTED_AFTER_INIT
+# Stock OPPO LK still runs the probe/compare/deinit path for this panel before
+# the real primary display init.  Keep that sequence even with one LCM driver.
+DEFINES += OPPO_FORCE_LCM_COMPARE_PROBE
+# Kernel lcm_gpio.c expects reset states on the lcm node, while this board's
+# overlay exposes them on mtkfb. Alias those states into the final kernel FDT.
+DEFINES += OPPO_FIX_LCM_GPIO_DT
+# Read-only display/DSI/FB register snapshot before kernel handoff.
+DEFINES += OPPO_DISPLAY_HANDOFF_DUMP
+# Stock unlocked LK does not draw the AVB orange warning during normal boot;
+# drawing it here triggers late framebuffer updates and leaves OVL busy.
+DEFINES += OPPO_SUPPRESS_ORANGE_STATE_UI
+# Directly clearing OVL/MUTEX also drains DL_VALID asynchronously and leaves
+# Linux with an incomplete DSI input relay, so keep this experiment disabled.
+# DEFINES += OPPO_DISPLAY_HANDOFF_MINIMAL_IDLE
+# The previous full soft-quiesce also changed DSI/RDMA state away from stock.
+# DEFINES += OPPO_DISPLAY_HANDOFF_STOCK_QUIESCE
+DEFINES += OPPO_LK_START_VIBRATE
+DEFINES += OPPO_EXTENDED_BOOT_MENU
+DEFINES += OPPO_MENU_OK_USE_POWER_KEY
+# Keep the boot/recovery framebuffer intact until the next stage draws over it.
+# DEFINES += OPPO_CLEAR_BOOT_MENU_LAYER_BEFORE_BOOT
+# DEFINES += OPPO_SKIP_BOOTMODE_KEY_LOOP
+# Use the stock UART state machine, but force its boot_arg inputs in
+# platform_early_init().
+# DEFINES += OPPO_FORCE_UART0_LOG
+# Let LK run the stock-style UART FIFO/LCR/baud setup; only the raw all-port
+# probes stay disabled.
+# DEFINES += OPPO_KEEP_PRELOADER_UART_CONFIG
+DEFINES += OPPO_SKIP_FACTORY_KEY_READ
+#DEFINES += WITH_DEBUG_FBCON=1
+CUSTOM_LK_USB_UNIQUE_SERIAL=yes
+MTK_TINYSYS_SCP_SUPPORT = yes
+MTK_TINYSYS_SSPM_SUPPORT = yes
+#DEFINES += NO_POWER_OFF=y
+#DEFINES += FPGA_BOOT_FROM_LK=y
+MTK_PROTOCOL1_RAT_CONFIG = Lf/Lt/W/G
+MTK_GOOGLE_TRUSTY_SUPPORT = no
+# OPPO A1K dump points to bq2560x/BQ25601 charger, not MT6370.
+# DEFINES += MTK_MT6370_PMU
+MTK_EFUSE_WRITER_SUPPORT = no
+MTK_SMC_ID_MGMT = yes
+DEVELOP_STAGE = SB
+MTK_LK_ENABLE_DCM = yes
+MTK_MT22_MODE :=H2
+MTK_PLATFORM_REVISED = MT6762
+# Stock normal boot imports init.mt6765.rc and ueventd.mt6765.rc.
+DEFINES += OPPO_FORCE_ANDROID_HARDWARE_MT6765
+# OPPO A1K bring-up: keep images headless and emit a padded flashable LK.
+NO_BOOT_LOGO_BUILD := yes
+
+FLASH_LK_BIN := $(BUILDDIR)/flash/lk.bin
+EXTRA_BUILDDEPS += $(FLASH_LK_BIN)
+
+$(FLASH_LK_BIN): $(OUTBIN)
+	@echo generating flashable lk image: $@
+	$(NOECHO)mkdir -p $(dir $@)
+	$(NOECHO)cp $(OUTBIN) $@
+	$(NOECHO)truncate -s 1048576 $@
+	@echo flashable lk image ready: $@
