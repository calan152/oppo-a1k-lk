+static bool oppo_cmdline_is_space(char c)
+{
+	return c == ' ' || c == '\t' || c == '\n' || c == '\r';
+}
+
+static bool oppo_cmdline_token_eq(const char *token, size_t token_len,
+				  const char *pattern)
+{
+	size_t pattern_len = strlen(pattern);
+
+	return token_len == pattern_len && memcmp(token, pattern, pattern_len) == 0;
+}
+
+static bool oppo_cmdline_token_has_prefix(const char *token, size_t token_len,
+					  const char *prefix)
+{
+	size_t prefix_len = strlen(prefix);
+
+	return token_len >= prefix_len && memcmp(token, prefix, prefix_len) == 0;
+}
+
+static const char *oppo_cmdline_token_end(const char *src)
+{
+	bool in_quote = false;
+
+	while (*src != '\0') {
+		if (*src == '"')
+			in_quote = !in_quote;
+		else if (!in_quote && oppo_cmdline_is_space(*src))
+			break;
+		src++;
+	}
+
+	return src;
+}
+
+#ifdef OPPO_DEDUP_NORMAL_CMDLINE
+static bool oppo_normal_cmdline_token_should_drop(const char *token,
+						  size_t token_len)
+{
+	if (oppo_cmdline_token_has_prefix(token, token_len,
+					  "androidboot.init_rc=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len,
+					  "androidboot.usbconfig=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len,
+					  "androidboot.mblogenable=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len,
+					  "androidboot.oppo_boot_mode=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len,
+					  "androidboot.mode=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "boot_mode="))
+		return true;
+
+	return false;
+}
+
+static bool oppo_normal_cmdline_dedupe_prefix(const char *token,
+					      size_t token_len,
+					      int *prefix_index)
+{
+	static const char *prefixes[] = {
+		"root=",
+		"init=",
+		"oppo_boot_mode=",
+		"is_lm3697=",
+		"short_c_battery_status=",
+		"short_c_switch_status=",
+		"short_c_feature_sw_status=",
+		"short_c_feature_hw_status=",
+		"androidboot.meta_log_disable=",
+		"androidboot.dtbo_idx=",
+		"androidboot.atm=",
+		"androidboot.verifiedbootstate=",
+		"androidboot.serialno=",
+		"androidboot.bootreason=",
+		"printk.disable_uart=",
+		"bootprof.pl_t=",
+		"bootprof.lk_t=",
+		"bootprof.logo_t=",
+		"boot_reason=",
+		"usb2jtag_mode=",
+		"mrdump_ddrsv=",
+		"mrdump_cb=",
+		"emmc_max_chunck_size=",
+		"oppo_custom_project=",
+		"board_id=",
+		"lcd_bias_id=",
+		NULL
+	};
+	int i;
+
+	for (i = 0; prefixes[i] != NULL; i++) {
+		if (oppo_cmdline_token_has_prefix(token, token_len, prefixes[i])) {
+			*prefix_index = i;
+			return true;
+		}
+	}
+
+	*prefix_index = -1;
+	return false;
+}
