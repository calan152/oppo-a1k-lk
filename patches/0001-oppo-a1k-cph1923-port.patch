+static void oppo_append_bootimg_cmdline(const char *cmdline,
+					uint32_t ramdisk_real_sz)
+{
+	static char filtered[OPPO_BOOTIMG_CMDLINE_FILTERED_SIZE];
+	const char *p = cmdline;
+	uint32_t out = 0;
+	uint32_t removed_root = 0;
+	uint32_t removed_skip = 0;
+	uint32_t removed_debug = 0;
+	bool truncated = false;
+	bool filter_boot_partition = oppo_boot_mode_uses_boot_partition(g_boot_mode);
+
+	if (cmdline == NULL || cmdline[0] == '\0')
+		return;
+
+	if (!filter_boot_partition) {
+		cmdline_append(cmdline);
+		return;
+	}
+
+	filtered[0] = '\0';
+	while (*p != '\0') {
+		const char *token;
+		size_t token_len;
+		uint32_t copy_len;
+		bool drop = false;
+
+		while (oppo_cmdline_is_space(*p))
+			p++;
+		if (*p == '\0')
+			break;
+
+		token = p;
+		while (*p != '\0' && !oppo_cmdline_is_space(*p))
+			p++;
+
+		token_len = (size_t)(p - token);
+		if (token_len == 0)
+			continue;
+
+		if (oppo_cmdline_token_has_prefix(token, token_len, "root=")) {
+			removed_root++;
+			drop = true;
+		}
+
+		if (oppo_cmdline_token_eq(token, token_len, "skip_initramfs")) {
+			removed_skip++;
+			drop = true;
+		}
+
+		if (oppo_bootimg_cmdline_token_should_drop(token, token_len)) {
+			removed_debug++;
+			drop = true;
+		}
+
+		if (drop)
+			continue;
+
+		if (out != 0) {
+			if (out + 1 >= OPPO_BOOTIMG_CMDLINE_FILTERED_SIZE) {
+				truncated = true;
+				break;
+			}
+			filtered[out++] = ' ';
+		}
+
+		copy_len = (uint32_t)token_len;
+		if (out + copy_len >= OPPO_BOOTIMG_CMDLINE_FILTERED_SIZE) {
+			copy_len = OPPO_BOOTIMG_CMDLINE_FILTERED_SIZE - out - 1;
+			truncated = true;
+		}
+
+		memcpy(filtered + out, token, copy_len);
+		out += copy_len;
+
+		if (truncated)
+			break;
+	}
+
+	filtered[out] = '\0';
+	dprintf(CRITICAL,
+		"[BOOT] bootimg cmdline filter: ramdisk=0x%x removed_root=%u removed_skip=%u removed_debug=%u truncated=%d\n",
+		ramdisk_real_sz, removed_root, removed_skip, removed_debug,
+		truncated);
+
+	if (out != 0)
+		cmdline_append(filtered);
+}
+
+int boot_linux_from_fastboot(void *bootimg_addr, unsigned bootimg_sz,
+			     BOOTMODE boot_mode,
+			     void (*ready_to_boot)(void))
+{
+	int ret = 0;
+	uint32_t kernel_target_addr = 0;
+	uint32_t ramdisk_target_addr = 0;
+	uint32_t tags_target_addr = 0;
+	uint32_t ramdisk_addr = 0;
+	uint32_t ramdisk_real_sz = 0;
+	uint32_t bootimg_min_sz = 0;
+	bool has_ramdisk = false;
+
+	if (!bootimg_addr || bootimg_sz < sizeof(struct bootimg_hdr)) {
+		dprintf(CRITICAL, "[FASTBOOT_BOOT] bad boot image buffer\n");
+		return -1;
+	}
+
+	if (boot_mode == RECOVERY_BOOT)
+		g_boot_mode = RECOVERY_BOOT;
+	else
+		g_boot_mode = NORMAL_BOOT;
+
+	if (g_boot_arg)
+		g_boot_arg->boot_mode = g_boot_mode;
+
+	oppo_prepare_normal_boot();
+	oppo_boot_mode_marker(g_boot_mode);
+
+	ret = load_bootinfo_bootimg(bootimg_addr);
+	if (ret) {
+		dprintf(CRITICAL,
+			"[FASTBOOT_BOOT] load_bootinfo_bootimg failed: ret=%d\n",
+			ret);
+		return ret;
+	}
+
+	bootimg_min_sz = get_bootimg_sz();
+	if (bootimg_min_sz > bootimg_sz) {
+		dprintf(CRITICAL,
+			"[FASTBOOT_BOOT] incomplete image: need=0x%x got=0x%x\n",
+			bootimg_min_sz, bootimg_sz);
+		return -1;
+	}
+
+	ret = prepare_kernel_dtb();
+	if (ret) {
+		dprintf(CRITICAL,
+			"[FASTBOOT_BOOT] prepare_kernel_dtb failed: ret=%d\n",
+			ret);
+		return ret;
+	}
+
+#ifdef OPPO_STOCK_RAMDISK_ROOT_CMDLINE
+	if (g_boot_mode == RECOVERY_BOOT) {
+		cmdline_append(FASTBOOT_CMDLINE_ROOT_RAM);
+	} else {
+		cmdline_append(FASTBOOT_CMDLINE_ROOT_BOOT_COMMON);
+	}
+#else
+	if (g_boot_mode == RECOVERY_BOOT)
+		cmdline_append(FASTBOOT_CMDLINE_ROOT_RAM);
+	else if (get_ramdisk_real_sz() == 0)
+		cmdline_append(FASTBOOT_CMDLINE_ROOT_SYSTEM_COMMON);
+	else
+		cmdline_append(FASTBOOT_CMDLINE_ROOT_BOOT_COMMON);
+#endif
+
+	cmdline_append("androidboot.verifiedbootstate=orange");
+	set_bootimg_loaded((uint32_t)bootimg_addr);
+
+	kernel_target_addr = get_kernel_target_addr();
+	ramdisk_target_addr = get_ramdisk_target_addr();
+	ramdisk_addr = get_ramdisk_addr();
+	ramdisk_real_sz = get_ramdisk_real_sz();
+	has_ramdisk = (ramdisk_real_sz != 0);
+	tags_target_addr = get_tags_addr();
+
+	PAL_ASSERT(kernel_target_addr != 0);
+	PAL_ASSERT(ramdisk_target_addr != 0);
+	PAL_ASSERT(ramdisk_addr != 0);
+
+#ifdef MTK_3LEVEL_PAGETABLE
+	arch_mmu_map((uint64_t)ramdisk_target_addr,
+		(uint32_t)ramdisk_target_addr,
+		MMU_MEMORY_TYPE_NORMAL_WRITE_BACK | MMU_MEMORY_AP_P_RW_U_NA,
+		ROUNDUP(LK_RAMDISK_MAX_SIZE, PAGE_SIZE));
