+		if (!log_store_name_match(reserved->name, "log_store"))
+			continue;
+		if (reserved->start < DRAM_PHY_ADDR || reserved->size < LOG_STORE_SIZE)
+			continue;
+
+		LOG_DEBUG("%s:reuse mblock log_store addr=0x%x size=0x%x map=%u.\n",
+			  MOD, (u32)reserved->start, (u32)reserved->size,
+			  reserved->mapping);
+		return (u32)reserved->start;
+	}
+
+	addr = mblock_reserve_ext(&g_boot_arg->mblock_info, LOG_STORE_SIZE,
+				  LOG_MEM_ALIGNMENT, 0x80000000, 1,
+				  "log_store");
+	if (addr) {
+		LOG_DEBUG("%s:reserved new mblock log_store addr=0x%x.\n",
+			  MOD, (u32)addr);
+		return (u32)addr;
+	}
+
+	LOG_DEBUG("%s:no usable mblock log_store buffer.\n", MOD);
+	return 0;
+}
+
+static void log_store_format_pl_lk_header(struct pl_lk_log *header)
+{
+	memset(header, 0, sizeof(*header));
+	header->sig = LOG_STORE_SIG;
+	header->buff_size = LOG_STORE_SIZE;
+	header->off_pl = sizeof(struct pl_lk_log);
+	header->off_lk = sizeof(struct pl_lk_log);
+	header->pl_flag = LOG_DEFAULT;
+	header->lk_flag = LOG_DEFAULT;
+}
+
+static bool log_store_bootarg_sram_valid(struct ram_console_memory_info *info)
+{
+	if (info == NULL)
+		return false;
+
+	return info->magic1 == MEM_MAGIC1 && info->magic2 == MEM_MAGIC2 &&
+	       info->sram_log_store_addr != 0 &&
+	       info->sram_log_store_size >= sizeof(struct sram_log_header);
+}
+
+static bool log_store_prepare_oppo_fallback_layout(unsigned int *addr,
+						   unsigned int *size)
+{
+	struct ram_console_memory_info *memory_info;
+	struct sram_log_header *header;
+	struct dram_buf_header *dram_header;
+	u32 dram_addr;
+
+	if (addr == NULL || size == NULL || g_boot_arg == NULL)
+		return false;
+
+	memory_info = (struct ram_console_memory_info *)
+		(OPPO_RAM_CONSOLE_SRAM_ADDR + OPPO_RAM_CONSOLE_MEMORY_INFO_OFFSET);
+	header = (struct sram_log_header *)OPPO_RAM_CONSOLE_LOG_STORE_ADDR;
+
+	if (!log_store_bootarg_sram_valid(memory_info)) {
+		LOG_DEBUG("%s:format OPPO ram_console info at 0x%x.\n",
+			  MOD, (u32)memory_info);
+		memset(memory_info, 0, sizeof(*memory_info));
+		memory_info->magic1 = MEM_MAGIC1;
+		memory_info->sram_log_store_addr = OPPO_RAM_CONSOLE_LOG_STORE_ADDR;
+		memory_info->sram_log_store_size = OPPO_RAM_CONSOLE_LOG_STORE_SIZE;
+		memory_info->magic2 = MEM_MAGIC2;
+	}
+
+	if (header->sig != SRAM_HEADER_SIG) {
+		LOG_DEBUG("%s:format OPPO sram log header at 0x%x.\n",
+			  MOD, (u32)header);
+		memset(header, 0, sizeof(*header));
+		header->sig = SRAM_HEADER_SIG;
+	}
+
+	dram_header = &header->dram_buf;
+	if (dram_header->sig != DRAM_HEADER_SIG ||
+	    dram_header->buf_addr < DRAM_PHY_ADDR ||
+	    dram_header->buf_size < LOG_STORE_SIZE ||
+	    dram_header->flag == BUFF_ALLOC_ERROR) {
+		dram_addr = log_store_find_dram_buffer();
+		if (dram_addr == 0)
+			return false;
+
+		memset(dram_header, 0, sizeof(*dram_header));
+		dram_header->sig = DRAM_HEADER_SIG;
+		dram_header->flag = BUFF_VALIE | CAN_FREE | NEED_SAVE_TO_EMMC |
+				    ARRAY_BUFF;
+		dram_header->buf_addr = dram_addr;
+		dram_header->buf_size = LOG_STORE_SIZE;
+		dram_header->buf_offsize = sizeof(struct pl_lk_log);
+		dram_header->buf_point = 0;
+		log_store_format_pl_lk_header(&header->dram_curlog_header);
+	} else if (header->dram_curlog_header.sig != LOG_STORE_SIG ||
+		   header->dram_curlog_header.buff_size != LOG_STORE_SIZE ||
+		   header->dram_curlog_header.off_pl != sizeof(struct pl_lk_log)) {
+		LOG_DEBUG("%s:format OPPO pl/lk log header at 0x%x.\n",
+			  MOD, (u32)&header->dram_curlog_header);
+		log_store_format_pl_lk_header(&header->dram_curlog_header);
+	}
+
+	g_boot_arg->ram_console_sram_addr = OPPO_RAM_CONSOLE_SRAM_ADDR;
+	g_boot_arg->ram_console_sram_size = OPPO_RAM_CONSOLE_SRAM_SIZE;
+	g_boot_arg->ram_console_def_type = RAM_CONSOLE_DEF_SRAM;
+	g_boot_arg->ram_console_memory_info_offset =
+		OPPO_RAM_CONSOLE_MEMORY_INFO_OFFSET;
+
+	*addr = memory_info->sram_log_store_addr;
+	*size = memory_info->sram_log_store_size;
+	log_store_debug_info.sram_addr = *addr;
+	log_store_debug_info.sram_size = *size;
+	LOG_DEBUG("%s:OPPO fallback sram=0x%x meminfo=0x%x log_store=0x%x size=0x%x.\n",
+		  MOD, g_boot_arg->ram_console_sram_addr,
+		  g_boot_arg->ram_console_memory_info_offset, *addr, *size);
+	return true;
+}
+
+static bool log_store_get_sram_info_safe(unsigned int *addr, unsigned int *size)
+{
+	struct ram_console_memory_info *memory_info;
+	unsigned int sram_addr;
+	unsigned int memory_info_offset;
+
+	if (addr == NULL || size == NULL)
+		return false;
+
+	if (g_boot_arg == NULL) {
+		LOG_DEBUG("%s:g_boot_arg is null, skip log_store_init.\n", MOD);
+		return false;
+	}
+
+	if (g_boot_arg->ram_console_sram_addr == 0 ||
+	    g_boot_arg->ram_console_memory_info_offset == 0) {
+		if (log_store_prepare_oppo_fallback_layout(addr, size))
+			return true;
+	}
+
+	sram_addr = g_boot_arg->ram_console_sram_addr;
+	memory_info_offset = g_boot_arg->ram_console_memory_info_offset;
+	log_store_debug_info.sram_addr = sram_addr;
+	log_store_debug_info.sram_size = g_boot_arg->ram_console_sram_size;
+	if (sram_addr == 0 || memory_info_offset == 0 ||
+	    memory_info_offset > 0x200000) {
+		LOG_DEBUG("%s:bad ram console args sram=0x%x off=0x%x size=0x%x.\n",
+		          MOD, sram_addr, memory_info_offset,
+		          g_boot_arg->ram_console_sram_size);
+		return false;
+	}
+
+	memory_info = (struct ram_console_memory_info *)(sram_addr + memory_info_offset);
+	if (memory_info->magic1 != MEM_MAGIC1 || memory_info->magic2 != MEM_MAGIC2) {
+		LOG_DEBUG("%s:ram console magic mismatch at 0x%x: 0x%x 0x%x.\n",
+		          MOD, (unsigned int)memory_info,
+		          memory_info->magic1, memory_info->magic2);
+		return false;
+	}
+
+	log_store_debug_info.sram_addr = memory_info->sram_log_store_addr;
+	log_store_debug_info.sram_size = memory_info->sram_log_store_size;
+	if (memory_info->sram_log_store_addr == 0 ||
+	    memory_info->sram_log_store_size < sizeof(struct sram_log_header)) {
+		LOG_DEBUG("%s:bad log_store sram info addr=0x%x size=0x%x.\n",
+		          MOD, memory_info->sram_log_store_addr,
+		          memory_info->sram_log_store_size);
+		return false;
+	}
+
+	*addr = memory_info->sram_log_store_addr;
+	*size = memory_info->sram_log_store_size;
+	return true;
+}
+
+bool lk_log_store_ready(void)
