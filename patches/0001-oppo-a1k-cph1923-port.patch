+static bool oppo_boot_mode_uses_boot_partition(BOOTMODE mode)
+{
+	switch (mode) {
+	case NORMAL_BOOT:
+	case META_BOOT:
+	case ADVMETA_BOOT:
+	case FACTORY_BOOT:
+	case ATE_FACTORY_BOOT:
+	case SW_REBOOT:
+	case ALARM_BOOT:
+#ifdef MTK_KERNEL_POWER_OFF_CHARGING
+	case KERNEL_POWER_OFF_CHARGING_BOOT:
+	case LOW_POWER_OFF_CHARGING_BOOT:
+#endif
+		return true;
+	default:
+		return false;
+	}
+}
