+static bool serial_field_is_default(const char *buf, unsigned int len)
+{
+	unsigned int default_len = strlen(DEFAULT_SERIAL_NUM);
+
+	return len == default_len &&
+		strncmp(buf, DEFAULT_SERIAL_NUM, default_len) == 0;
+}
+
+static bool copy_serial_field(char *dst, const char *src,
+	unsigned int max_len, const char *label)
+{
+	unsigned int len = serial_field_len(src, max_len);
+
+	if (len > SN_BUF_LEN)
+		len = SN_BUF_LEN;
+
+	if (len == 0) {
+		pal_log_err("[SERIAL] proinfo %s empty\n", label);
+		return false;
+	}
+
+	if (serial_field_is_default(src, len)) {
+		pal_log_err("[SERIAL] proinfo %s is default\n", label);
+		return false;
+	}
+
+	strncpy(dst, src, len);
+	dst[len] = '\0';
+	pal_log_err("[SERIAL] proinfo %s -> \"%s\"\n", label, dst);
+	return true;
+}
+
+static inline int read_product_info(char *buf)
+{
+	static char proinfo[512];
+	int ret;
+
+	if (!buf)
+		return 0;
+
+	memset(proinfo, 0, sizeof(proinfo));
+	ret = mboot_recovery_load_raw_part("proinfo",
+		(unsigned long *)proinfo, sizeof(proinfo));
+	if (ret < 0) {
+		pal_log_err("[SERIAL] read proinfo failed, ret=%d\n", ret);
+		return 0;
+	}
+
+	/* PRODUCT_INFO: barcode[64], IMEI[4] (40), BT/WiFi (12), ADBSeriaNo[20]. */
+	if (copy_serial_field(buf, proinfo, 64, "barcode"))
+		return strlen(buf);
+
+	if (copy_serial_field(buf, proinfo + 0x74, 20, "adb"))
+		return strlen(buf);
+
+	pal_log_err("[SERIAL] proinfo has no non-default serial candidate\n");
+	return 0;
+}
