+	u32 mode;
+	u32 length;
+	u32 nonrst2;
+
+	if (timeout_sec == 0)
+		timeout_sec = 20;
+
+	length = (timeout_sec * (1 << 6)) << 5;
+	DRV_WriteReg32(MTK_WDT_LENGTH, length | MTK_WDT_LENGTH_KEY);
+
+	nonrst2 = DRV_Reg32(MTK_WDT_NONRST_REG2);
+	nonrst2 = (nonrst2 & ~(RGU_STAGE_MASK << MTK_WDT_NONRST2_STAGE_OFS))
+		| (RGU_STAGE_KERNEL << MTK_WDT_NONRST2_STAGE_OFS);
+	DRV_WriteReg32(MTK_WDT_NONRST_REG2, nonrst2);
+
+	mode = DRV_Reg32(MTK_WDT_MODE);
+	mode &= ~(MTK_WDT_MODE_IRQ | MTK_WDT_MODE_IRQ_LEVEL_EN |
+		  MTK_WDT_MODE_EXT_POL | MTK_WDT_MODE_EXTEN);
+	mode |= MTK_WDT_MODE_KEY | MTK_WDT_MODE_ENABLE |
+		MTK_WDT_MODE_DUAL_MODE | MTK_WDT_MODE_AUTO_RESTART;
+	DRV_WriteReg32(MTK_WDT_MODE, mode);
+	DRV_WriteReg32(MTK_WDT_RESTART, MTK_WDT_RESTART_KEY);
+
+	WDTCRI("kernel handoff watchdog armed: %u sec MODE=0x%x LENGTH=0x%x\n",
+	       timeout_sec, DRV_Reg32(MTK_WDT_MODE), DRV_Reg32(MTK_WDT_LENGTH));
+}
