+		oppo_dputc_seen = 1;
+		oppo_atf_stage_uart_dputc_once();
+	}
+	if (c == '\n')
+		oppo_early_log_char('\r');
+	oppo_early_log_char(c);
+
+	if (c == '\n')
 		uart_putc('\r');
-		lk_log_store('\r');
+	if (!oppo_before_putc_seen) {
+		oppo_before_putc_seen = 1;
+		oppo_atf_stage_uart_before_putc();
 	}
 	uart_putc(c);
-	lk_log_store(c);
+	if (!oppo_after_putc_seen) {
+		oppo_after_putc_seen = 1;
+		oppo_atf_stage_uart_after_putc();
+	}
+
+	if (oppo_stock_lk_log_store_enable) {
+		if (c == '\n')
+			lk_log_store('\r');
+		lk_log_store(c);
