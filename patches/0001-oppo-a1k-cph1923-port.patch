+void mt_disp_clear_kernel_framebuffer(void)
+{
+#ifdef OPPO_CLEAR_BOOT_MENU_LAYER_BEFORE_BOOT
+	unsigned int vram_size;
+
+	if (!fb_addr)
+		return;
+
+	vram_size = DISP_GetVRamSize();
+	if (!vram_size)
+		return;
+
+	memset(fb_addr, 0x0, vram_size);
+	arch_clean_cache_range((unsigned int)fb_addr, vram_size);
+	primary_display_trigger(TRUE);
+	dprintf(CRITICAL, "[DISP] kernel framebuffer cleared: addr=0x%x size=0x%x\n",
+		(unsigned int)fb_addr, vram_size);
+#endif
+}
+
+void mt_disp_prepare_recovery_handoff(void)
+{
+#ifdef OPPO_CLEAR_BOOT_MENU_LAYER_BEFORE_BOOT
+	disp_input_config input;
+	unsigned int vram_size;
+
+	if (!fb_addr || !fb_size)
+		return;
+
+	vram_size = DISP_GetVRamSize();
+	if (!vram_size)
+		return;
+
+	memset(fb_addr, 0x0, vram_size);
+	arch_clean_cache_range((unsigned int)fb_addr, vram_size);
+
+	memset(&input, 0, sizeof(input));
+	input.layer     = FB_LAYER;
+	input.layer_en  = 1;
+	input.fmt       = redoffset_32bit ? eBGRA8888 : eRGBA8888;
+	input.addr      = fb_addr_pa;
+	input.src_x     = 0;
+	input.src_y     = 0;
+	input.src_w     = CFG_DISPLAY_WIDTH;
+	input.src_h     = CFG_DISPLAY_HEIGHT;
+	input.src_pitch = ALIGN_TO(CFG_DISPLAY_WIDTH, MTK_FB_ALIGNMENT) * 4;
+	input.dst_x     = 0;
+	input.dst_y     = 0;
+	input.dst_w     = CFG_DISPLAY_WIDTH;
+	input.dst_h     = CFG_DISPLAY_HEIGHT;
+	input.aen       = 1;
+	input.alpha     = 0xff;
+	primary_display_config_input(&input);
+
+	DISP_REG_SET(NULL, DISP_REG_OVL_SRC_CON, 0x1);
+	DISP_REG_SET(NULL, DISP_REG_OVL_SRC_CON + DISP_INDEX_OFFSET, 0x0);
+	DISP_REG_SET(NULL, DISP_REG_OVL_SRC_CON + 2 * DISP_INDEX_OFFSET, 0x0);
+	primary_display_trigger(TRUE);
+	mdelay(50);
+
+	dprintf(CRITICAL,
+		"[DISP] recovery handoff: fb=0x%x pa=0x%x vram=0x%x ovl_src=0x%x ovl2l=0x%x\n",
+		(unsigned int)fb_addr, fb_addr_pa, vram_size,
+		DISP_REG_GET(DISP_REG_OVL_SRC_CON),
+		DISP_REG_GET(DISP_REG_OVL_SRC_CON + DISP_INDEX_OFFSET));
+#endif
+}
