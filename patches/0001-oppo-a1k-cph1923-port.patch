+void mt_disp_disable_boot_menu_layer(void)
+{
+#ifdef OPPO_CLEAR_BOOT_MENU_LAYER_BEFORE_BOOT
+	disp_input_config input;
+	unsigned int boot_menu_addr;
+
+	if (!fb_addr || !fb_size)
+		return;
+
+	boot_menu_addr = (unsigned int)fb_addr + fb_size;
+	memset((void *)boot_menu_addr, 0x0, fb_size);
+	arch_clean_cache_range(boot_menu_addr, fb_size);
+
+	OVLLayerSwitch(DISP_MODULE_OVL0, BOOT_MENU_LAYER, 0, NULL);
+	OVLLayerSwitch(DISP_MODULE_OVL0_2L, 0, 0, NULL);
+	OVLLayerSwitch(DISP_MODULE_OVL0_2L, 1, 0, NULL);
+
+	memset(&input, 0, sizeof(input));
+	input.layer = BOOT_MENU_LAYER;
+	input.layer_en = 0;
+	primary_display_config_input(&input);
+
+	OVLLayerSwitch(DISP_MODULE_OVL0, BOOT_MENU_LAYER, 0, NULL);
+	OVLLayerSwitch(DISP_MODULE_OVL0_2L, 0, 0, NULL);
+	OVLLayerSwitch(DISP_MODULE_OVL0_2L, 1, 0, NULL);
+
+	primary_display_trigger(TRUE);
+	dprintf(CRITICAL, "[DISP] boot menu/overlay layers forced off\n");
+#endif
+}
