+static bool avb_cmdline_is_vbmeta_measurement(const char *token, size_t token_len)
+{
+	return avb_cmdline_token_has_prefix(token, token_len,
+					    "androidboot.vbmeta.hash_alg=") ||
+	       avb_cmdline_token_has_prefix(token, token_len,
+					    "androidboot.vbmeta.size=") ||
