+static long boot_find_android_magic(const uint8_t *buf, size_t len)
+{
+	size_t i;
+
+	if (len < BOOTIMG_MAGIC_SZ)
+		return -1;
+
+	for (i = 0; i <= len - BOOTIMG_MAGIC_SZ; i++) {
+		if (!memcmp(buf + i, BOOTIMG_MAGIC, BOOTIMG_MAGIC_SZ))
+			return (long)i;
+	}
+
+	return -1;
