+static void oppo_lk_start_vibrate(void)
+{
+	unsigned short ret_vosel;
+	unsigned short ret_lp;
+	unsigned short ret_en;
+	unsigned short ret_op_en;
+
+	/* MT6357 VIBR table: raw VOSEL 10 == 2.8V, strong enough but not max. */
+	ret_vosel = pmic_set_register_value(PMIC_RG_VIBR_VOSEL, OPPO_LK_VIBR_VOSEL_2V8);
+	ret_lp = pmic_set_register_value(PMIC_RG_LDO_VIBR_LP, 0);
+	ret_en = pmic_set_register_value(PMIC_RG_LDO_VIBR_EN, 1);
+	ret_op_en = pmic_set_register_value(PMIC_RG_LDO_VIBR_SW_OP_EN, 1);
+	dprintf(CRITICAL,
+		"[OPPO_VIBR] LK start vibrate on %ums vosel=0x%x ret=%u/%u/%u/%u\n",
+		OPPO_LK_VIBR_MS, OPPO_LK_VIBR_VOSEL_2V8,
+		ret_vosel, ret_lp, ret_en, ret_op_en);
+
+	mdelay(OPPO_LK_VIBR_MS);
+
+	pmic_set_register_value(PMIC_RG_LDO_VIBR_SW_OP_EN, 0);
+	pmic_set_register_value(PMIC_RG_LDO_VIBR_EN, 0);
+	dprintf(CRITICAL, "[OPPO_VIBR] LK start vibrate off\n");
+}
