+
+static inline unsigned int oppo_raw_readl(unsigned int addr)
+{
+	unsigned int value = *(volatile unsigned int *)addr;
+	__asm__ volatile("dsb sy" ::: "memory");
+	return value;
+}
+
+static void oppo_kmain_uart_wait_empty(void)
+{
+	unsigned int timeout = 100000;
+
+	while (timeout--) {
+		if ((oppo_raw_readl(OPPO_UART_LSR) &
+		     (OPPO_UART_LSR_THRE | OPPO_UART_LSR_TEMT)) ==
+		    (OPPO_UART_LSR_THRE | OPPO_UART_LSR_TEMT))
+			break;
+	}
+}
+
+static void oppo_kmain_uart_putc(char c)
+{
+	if (c == '\n') {
+		oppo_raw_writel('\r', OPPO_UART_THR);
+		oppo_kmain_uart_wait_empty();
+	}
+
+	oppo_raw_writel((unsigned int)c, OPPO_UART_THR);
+	oppo_kmain_uart_wait_empty();
+}
+
+static void oppo_kmain_uart_puts(const char *s)
+{
+	while (*s)
+		oppo_kmain_uart_putc(*s++);
+}
