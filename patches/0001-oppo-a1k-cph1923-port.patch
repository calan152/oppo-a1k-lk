+	sm5109_i2c.mode = ST_MODE;
+	sm5109_i2c.speed = 100;
+
+	ret = i2c_write_read(&sm5109_i2c, &ret_data, 1, 1);
+	if (ret != I2C_OK) {
+		LCM_LOGI("%s: I2CR[0x%02x] failed, ret=%d\n",
