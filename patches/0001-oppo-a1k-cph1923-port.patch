+static void oppo_kmain_uart_probe(void)
+{
+	unsigned int lcr;
+
+	oppo_raw_writel(OPPO_TOP_UART_SEL_26M_BIT, OPPO_CLK_CFG_2_CLR);
+	oppo_raw_writel(OPPO_TOP_UART_UPDATE_BIT, OPPO_CLK_CFG_UPDATE);
+	oppo_raw_writel(OPPO_UART0_CG_BIT, OPPO_UART_IFR2_CLR);
+
+	oppo_raw_writel(0x07, OPPO_UART_FCR);
+	oppo_raw_writel(0x03, OPPO_UART_LCR);
+	oppo_raw_writel(0x03, OPPO_UART_HIGHSPEED);
+
+	lcr = oppo_raw_readl(OPPO_UART_LCR);
+	oppo_raw_writel(lcr | OPPO_UART_LCR_DLAB, OPPO_UART_LCR);
+	oppo_raw_writel(0x01, OPPO_UART_THR);
+	oppo_raw_writel(0x00, OPPO_UART0_BASE + 0x04);
+	oppo_raw_writel(27, OPPO_UART_SAMPLE_COUNT);
+	oppo_raw_writel(13, OPPO_UART_SAMPLE_POINT);
+	oppo_raw_writel(lcr, OPPO_UART_LCR);
+
+	oppo_kmain_uart_puts("\n[OPPO_KMAIN_RAW_UART]\n");
+}
