+
+	strlcpy(part_name, arg, sizeof(part_name));
+	offset_arg = strchr(part_name, ':');
+	if (offset_arg == NULL) {
+		fastboot_fail("missing offset");
+		return;
+	}
+	*offset_arg++ = '\0';
+	size_arg = strchr(offset_arg, ':');
+	if (size_arg == NULL) {
+		fastboot_fail("missing size");
+		return;
+	}
+	*size_arg++ = '\0';
+
+	part_size = partition_get_size_by_name(part_name);
+	if (part_size == 0) {
+		fastboot_fail("partition not found");
+		return;
+	}
+
+	offset = strtoul(offset_arg, NULL, 0);
+	fetch_size = strtoul(size_arg, NULL, 0);
+	if (fetch_size == 0 || fetch_size > FASTBOOT_FETCH_MAX_SIZE) {
+		fastboot_fail("bad fetch size");
+		return;
+	}
+	if ((u64)offset >= part_size || (u64)offset + fetch_size > part_size) {
+		fastboot_fail("fetch out of range");
+		return;
+	}
+	if (download_base == NULL) {
+		fastboot_fail("download buffer is null");
+		return;
+	}
+
+	dprintf(ALWAYS,
+		"[fastboot_fetch] %s off=0x%lx size=0x%lx base=0x%x\n",
+		part_name, offset, fetch_size, (unsigned int)download_base);
+	read_len = partition_read(part_name, (off_t)offset, (u8 *)download_base,
+		(size_t)fetch_size);
+	if (read_len != (ssize_t)fetch_size) {
+		dprintf(ALWAYS,
+			"[fastboot_fetch] read failed: %d/0x%lx\n",
+			(int)read_len, fetch_size);
+		fastboot_fail("fetch read failed");
+		return;
+	}
+
+	download_size = (unsigned)fetch_size;
+	if (fastboot_upload_buffer(download_base, download_size) < 0)
+		return;
+
+	fastboot_okay("");
+}
