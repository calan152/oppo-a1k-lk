+	const char *name = "none";
+	char marker[96];
+	int marker_len;
+
+	atf_expdb_dev = dev;
+	atf_expdb_log_header = log_header;
+
+	written = kedump_plat_savelog(AEE_PLAT_ATF_LAST_LOG, 0, &len,
+				      expdb_append_atf_log);
+	if (written) {
+		name = "last";
+	} else {
+		written = kedump_plat_savelog(AEE_PLAT_ATF_CRASH_REPORT, 0, &len,
+					      expdb_append_atf_log);
+		if (written) {
+			name = "crash";
+		} else {
+			written = kedump_plat_savelog(AEE_PLAT_ATF_RAW_LOG, 0, &len,
+						      expdb_append_atf_log);
+			if (written)
+				name = "raw";
+		}
+	}
+
+	atf_expdb_dev = NULL;
+	atf_expdb_log_header = NULL;
+
+	marker_len = snprintf(marker, sizeof(marker),
+			      "\n[OPPO_ATF_LOG] saved type=%s len=%d wrote=%u\n",
+			      name, len, written);
+	if (marker_len > 0) {
+		if (marker_len > (int)sizeof(marker))
+			marker_len = sizeof(marker);
+		expdb_append_log_data(dev, log_header, (uchar *)marker, marker_len);
+	}
