+void mt_disp_handoff_quiesce(void)
+{
+#ifdef OPPO_DISPLAY_HANDOFF_MINIMAL_IDLE
+	unsigned int ovl_en_before;
+	unsigned int ovl2l_en_before;
+	unsigned int mutex_en_before;
+	unsigned int dl_valid0_before;
+	unsigned int dl_valid1_before;
+	unsigned int dl_valid2_before;
+
+	/*
+	 * Stock OPPO LK reaches kernel handoff with the display path still valid,
+	 * but with OVL/mutex no longer actively driving LK layers.  Do the smallest
+	 * possible idle step here: leave routing, RDMA, DSI and layer registers
+	 * intact, and only stop the OVL engines plus mutex enable bit.
+	 */
+	ovl_en_before = DISP_REG_GET(DISP_REG_OVL_EN);
+	ovl2l_en_before = DISP_REG_GET(DISP_REG_OVL_EN + DISP_INDEX_OFFSET);
+	mutex_en_before = DISP_REG_GET(DISP_REG_CONFIG_MUTEX_EN(0));
+	dl_valid0_before = DISP_REG_GET(DISP_REG_CONFIG_DISP_DL_VALID_0);
+	dl_valid1_before = DISP_REG_GET(DISP_REG_CONFIG_DISP_DL_VALID_1);
+	dl_valid2_before = DISP_REG_GET(DISP_REG_CONFIG_DISP_DL_VALID_2);
+
+	DISP_REG_SET(NULL, DISP_REG_CONFIG_MUTEX_EN(0), 0x0);
+	DISP_REG_SET(NULL, DISP_REG_OVL_EN, 0x0);
+	DISP_REG_SET(NULL, DISP_REG_OVL_EN + DISP_INDEX_OFFSET, 0x0);
+	mdelay(2);
+
+	dprintf(CRITICAL,
+		"[OPPO_DISP_HANDOFF] minimal idle before ovl_en=0x%x/0x%x mutex_en=0x%x dl_valid=0x%x/0x%x/0x%x after ovl_en=0x%x/0x%x mutex_en=0x%x dl_valid=0x%x/0x%x/0x%x\n",
+		ovl_en_before, ovl2l_en_before, mutex_en_before,
+		dl_valid0_before, dl_valid1_before, dl_valid2_before,
+		DISP_REG_GET(DISP_REG_OVL_EN),
+		DISP_REG_GET(DISP_REG_OVL_EN + DISP_INDEX_OFFSET),
+		DISP_REG_GET(DISP_REG_CONFIG_MUTEX_EN(0)),
+		DISP_REG_GET(DISP_REG_CONFIG_DISP_DL_VALID_0),
+		DISP_REG_GET(DISP_REG_CONFIG_DISP_DL_VALID_1),
+		DISP_REG_GET(DISP_REG_CONFIG_DISP_DL_VALID_2));
+#endif
+#ifdef OPPO_DISPLAY_HANDOFF_STOCK_QUIESCE
+	unsigned int i;
+	unsigned int wait_ms;
+	unsigned int dsi_intsta_before;
+	unsigned int ovl_sta_before;
+	unsigned int rdma_int_before;
+
+	dprintf(CRITICAL, "[OPPO_DISP_HANDOFF] quiesce OVL/mutex before kernel\n");
+
+	if (fb_addr)
+		arch_clean_cache_range((unsigned int)fb_addr, DISP_GetFBRamSize());
+	primary_display_trigger(TRUE);
+	mdelay(20);
+
+	dsi_intsta_before = DISP_REG_GET(DSI_REG_BASE[0] + DISP_REG_DSI_INTSTA);
+	ovl_sta_before = DISP_REG_GET(DISP_REG_OVL_STA);
+	rdma_int_before = DISP_REG_GET(DISP_REG_RDMA_INT_STATUS);
+
+	/*
+	 * MT6765/Cervino exposes OVL0 and OVL0_2L here. OVL1_2L is marked as
+	 * absent in the register map, so do not walk a third DISP_INDEX_OFFSET.
+	 */
+	for (i = 0; i < 2; i++) {
+		unsigned int off = i * DISP_INDEX_OFFSET;
+
+		DISP_REG_SET(NULL, DISP_REG_OVL_INTEN + off, 0x0);
+		DISP_REG_SET(NULL, DISP_REG_OVL_EN + off, 0x0);
+		DISP_REG_SET(NULL, DISP_REG_OVL_INTSTA + off, 0x0);
+		DISP_REG_SET(NULL, DISP_REG_OVL_SRC_CON + off, 0x0);
+		DISP_REG_SET(NULL, DISP_REG_OVL_L0_ADDR + off, 0x0);
+		DISP_REG_SET(NULL, DISP_REG_OVL_L0_PITCH + off, 0x0);
+		DISP_REG_SET(NULL, DISP_REG_OVL_L1_ADDR + off, 0x0);
+		DISP_REG_SET(NULL, DISP_REG_OVL_L1_PITCH + off, 0x0);
+	}
+
+	DISP_REG_SET(NULL, DISP_REG_OVL_ROI_SIZE, 0x80000100);
+	DISP_REG_SET(NULL, DISP_REG_OVL_ROI_BGCLR, 0x10001);
+	DISP_REG_SET(NULL, DISP_REG_OVL_L0_CON, 0x1e00320);
+
+	DISP_REG_SET(NULL, DISP_REG_CONFIG_MUTEX_EN(0), 0x0);
+	DISP_REG_SET(NULL, DISP_REG_CONFIG_MUTEX_MOD0(0), 0x0);
+	DISP_REG_SET(NULL, DISP_REG_CONFIG_MUTEX_SOF(0), 0x0);
+
+	for (wait_ms = 0; wait_ms < 50; wait_ms++) {
+		if ((DISP_REG_GET(DISP_REG_OVL_STA) & 0x1) == 0 &&
+		    (DISP_REG_GET(DISP_REG_OVL_STA + DISP_INDEX_OFFSET) & 0x1) == 0)
+			break;
+		mdelay(1);
+	}
+
+	for (i = 0; i < 2; i++) {
+		unsigned int off = i * DISP_INDEX_OFFSET;
+
+		DISP_REG_SET(NULL, DISP_REG_OVL_INTSTA + off, 0x0);
+	}
+	DISP_REG_SET(NULL, DISP_REG_RDMA_INT_STATUS, 0x0);
+
+	dprintf(CRITICAL,
+		"[OPPO_DISP_HANDOFF] soft quiesce ovl_count=2 wait=%u before dsi_intsta=0x%x ovl_sta=0x%x rdma_int=0x%x after ovl_sta=0x%x/0x%x ovl_int=0x%x rdma_int=0x%x\n",
+		wait_ms,
+		dsi_intsta_before, ovl_sta_before, rdma_int_before,
+		DISP_REG_GET(DISP_REG_OVL_STA),
+		DISP_REG_GET(DISP_REG_OVL_STA + DISP_INDEX_OFFSET),
+		DISP_REG_GET(DISP_REG_OVL_INTSTA),
+		DISP_REG_GET(DISP_REG_RDMA_INT_STATUS));
+#endif
+}
