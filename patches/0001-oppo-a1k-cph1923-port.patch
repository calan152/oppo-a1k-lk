+#define OPPO_CRT0_RESERVE_PART          "opporeserve1"
+#define OPPO_CRT0_RESERVE_MARKER_OFF    0x7FF000
+#define OPPO_CRT0_RESERVE_MARKER_SIZE   512
+
+extern BOOT_ARGUMENT *g_boot_arg;
+extern unsigned int OPPO_CRT0_LK_STARTED_MARKER[];
+
+static void oppo_flush_crt0_marker_to_reserve(void)
+{
+	static unsigned char marker_block[OPPO_CRT0_RESERVE_MARKER_SIZE] __attribute__((aligned(512)));
+	const char marker_sig[] = "LK_Started";
+	u64 part_base;
+	u64 part_size;
+	ssize_t ret;
+
+	if (memcmp((void *)OPPO_CRT0_LK_STARTED_MARKER, marker_sig,
+		   sizeof(marker_sig) - 1) != 0) {
+		dprintf(CRITICAL,
+			"[OPPO_CRT0] marker is absent: %08x %08x %08x %08x\n",
+			OPPO_CRT0_LK_STARTED_MARKER[0],
+			OPPO_CRT0_LK_STARTED_MARKER[1],
+			OPPO_CRT0_LK_STARTED_MARKER[2],
+			OPPO_CRT0_LK_STARTED_MARKER[3]);
+		return;
+	}
+
+	part_base = partition_get_offset_by_name(OPPO_CRT0_RESERVE_PART);
+	part_size = partition_get_size_by_name(OPPO_CRT0_RESERVE_PART);
+	if (part_size < OPPO_CRT0_RESERVE_MARKER_OFF + OPPO_CRT0_RESERVE_MARKER_SIZE) {
+		dprintf(CRITICAL,
+			"[OPPO_CRT0] %s is too small: size=0x%llx marker_off=0x%x\n",
+			OPPO_CRT0_RESERVE_PART,
+			part_size,
+			OPPO_CRT0_RESERVE_MARKER_OFF);
+		return;
+	}
+
+	memset(marker_block, 0, sizeof(marker_block));
+	snprintf((char *)marker_block, sizeof(marker_block),
+		 "LK_Started\n"
+		 "source=crt0.S\n"
+		 "partition=%s\n"
+		 "partition_offset=0x%08x\n"
+		 "physical_offset=0x%llx\n"
+		 "boot_reason=%u\n"
+		 "boot_mode=%u\n"
+		 "marker_words=%08x %08x %08x %08x\n",
+		 OPPO_CRT0_RESERVE_PART,
+		 OPPO_CRT0_RESERVE_MARKER_OFF,
+		 part_base + OPPO_CRT0_RESERVE_MARKER_OFF,
+		 g_boot_arg->boot_reason,
+		 g_boot_arg->boot_mode,
+		 OPPO_CRT0_LK_STARTED_MARKER[0],
+		 OPPO_CRT0_LK_STARTED_MARKER[1],
+		 OPPO_CRT0_LK_STARTED_MARKER[2],
+		 OPPO_CRT0_LK_STARTED_MARKER[3]);
+
+	ret = partition_write(OPPO_CRT0_RESERVE_PART,
+			      OPPO_CRT0_RESERVE_MARKER_OFF,
+			      marker_block,
+			      sizeof(marker_block));
+	dprintf(CRITICAL,
+		"[OPPO_CRT0] write LK_Started to %s+0x%x ret=%ld\n",
+		OPPO_CRT0_RESERVE_PART,
+		OPPO_CRT0_RESERVE_MARKER_OFF,
+		ret);
+}
