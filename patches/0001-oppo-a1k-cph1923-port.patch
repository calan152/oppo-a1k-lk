+static uint32_t avb_cmdline_drop_vbmeta_measurements(char *cmdline)
+{
+	char *readp;
+	char *writep;
+	uint32_t removed = 0;
+	bool first = true;
+
+	if (cmdline == NULL || cmdline[0] == '\0')
+		return 0;
+
+	readp = cmdline;
+	writep = cmdline;
+
+	while (*readp != '\0') {
+		char *token;
+		size_t token_len;
+
+		while (avb_cmdline_is_space(*readp))
+			readp++;
+
+		if (*readp == '\0')
+			break;
+
+		token = readp;
+		while (*readp != '\0' && !avb_cmdline_is_space(*readp))
+			readp++;
+
+		token_len = (size_t)(readp - token);
+		if (token_len == 0)
+			continue;
+
+		if (avb_cmdline_is_vbmeta_measurement(token, token_len)) {
+			removed++;
+			continue;
+		}
+
+		if (!first)
+			*writep++ = ' ';
+
+		memmove(writep, token, token_len);
+		writep += token_len;
+		first = false;
+	}
+
+	*writep = '\0';
+	return removed;
+}
