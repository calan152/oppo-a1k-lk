+static bool oppo_bootimg_cmdline_token_should_drop(const char *token,
+	size_t token_len)
+{
+#ifdef OPPO_DROP_BOOTIMG_DIAG_CMDLINE
+	if (oppo_cmdline_token_eq(token, token_len, "ignore_loglevel") ||
+	    oppo_cmdline_token_eq(token, token_len, "initcall_debug") ||
+	    oppo_cmdline_token_eq(token, token_len, "oops=panic") ||
+	    oppo_cmdline_token_eq(token, token_len, "kmemleak=on"))
+		return true;
+
+	if (oppo_cmdline_token_has_prefix(token, token_len, "earlycon=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "loglevel=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "initcall_debug=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "printk.devkmsg=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "panic=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "panic_on_oops=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "softlockup_panic=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "hung_task_panic=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "androidboot.boot_trace=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "androidboot.init_rc=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "androidboot.usbconfig=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "androidboot.mblogenable=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "androidboot.oppo_boot_mode=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "androidboot.mode=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "oppo_boot_mode=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "boot_mode=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "is_lm3697=") ||
+	    oppo_cmdline_token_has_prefix(token, token_len, "ramoops."))
+		return true;
+#else
+	(void)token;
+	(void)token_len;
+#endif
+
+	return false;
+}
