+static void oppo_sanitize_normal_cmdline(void)
+{
+	static char sanitized[CMDLINE_LEN];
+	const char *src = cmdline_get();
+	uint32_t out = 0;
+	uint32_t removed = 0;
+	uint32_t deduped = 0;
+	bool seen_prefix[32] = { false };
+	bool seen_skip_initramfs = false;
+	bool seen_ro = false;
+	bool seen_rootwait = false;
+
+	if (g_boot_mode != NORMAL_BOOT || src == NULL || src[0] == '\0')
+		return;
+
+	while (*src != '\0') {
+		const char *token;
+		size_t token_len;
+		uint32_t copy_len;
+		bool drop = false;
+		int prefix_index = -1;
+
+		while (oppo_cmdline_is_space(*src))
+			src++;
+		if (*src == '\0')
+			break;
+
+		token = src;
+		src = oppo_cmdline_token_end(src);
+		token_len = (size_t)(src - token);
+		if (token_len == 0)
+			continue;
+
+		if (oppo_normal_cmdline_token_should_drop(token, token_len)) {
+			removed++;
+			continue;
+		}
+
+		if (oppo_cmdline_token_eq(token, token_len, "skip_initramfs")) {
+			if (seen_skip_initramfs) {
+				deduped++;
+				continue;
+			}
+			seen_skip_initramfs = true;
+		} else if (oppo_cmdline_token_eq(token, token_len, "ro")) {
+			if (seen_ro) {
+				deduped++;
+				continue;
+			}
+			seen_ro = true;
+		} else if (oppo_cmdline_token_eq(token, token_len, "rootwait")) {
+			if (seen_rootwait) {
+				deduped++;
+				continue;
+			}
+			seen_rootwait = true;
+		} else if (oppo_normal_cmdline_dedupe_prefix(token, token_len,
+							     &prefix_index)) {
+			if (prefix_index >= 0 &&
+			    prefix_index < (int)(sizeof(seen_prefix) / sizeof(seen_prefix[0])) &&
+			    seen_prefix[prefix_index]) {
+				deduped++;
+				continue;
+			}
+			if (prefix_index >= 0 &&
+			    prefix_index < (int)(sizeof(seen_prefix) / sizeof(seen_prefix[0])))
+				seen_prefix[prefix_index] = true;
+		}
+
+		if (out != 0) {
+			if (out + 1 >= CMDLINE_LEN)
+				break;
+			sanitized[out++] = ' ';
+		}
+
+		copy_len = (uint32_t)token_len;
+		if (out + copy_len >= CMDLINE_LEN)
+			copy_len = CMDLINE_LEN - out - 1;
+
+		memcpy(sanitized + out, token, copy_len);
+		out += copy_len;
+
+		if (copy_len != token_len)
+			break;
+	}
+
+	sanitized[out] = '\0';
+	cmdline_overwrite(sanitized);
+
+	if (removed || deduped)
+		dprintf(CRITICAL,
+			"[BOOT] normal cmdline sanitized: removed=%u deduped=%u\n",
+			removed, deduped);
+}
+#endif
+
+#ifdef OPPO_FORCE_MINIMAL_NORMAL_CMDLINE
+static bool oppo_minimal_cmdline_token_matches(const char *token,
+					       size_t token_len,
+					       const char *pattern)
+{
+	size_t pattern_len = strlen(pattern);
+
+	if (pattern_len == 0)
+		return false;
+
+	if (pattern[pattern_len - 1] == '=')
+		return token_len >= pattern_len &&
+		       memcmp(token, pattern, pattern_len) == 0;
+
+	return token_len == pattern_len && memcmp(token, pattern, pattern_len) == 0;
+}
+
+static bool oppo_minimal_cmdline_has_token(const char *cmdline,
+					   const char *pattern)
+{
+	const char *src = cmdline;
+
+	if (src == NULL)
+		return false;
+
+	while (*src != '\0') {
+		const char *token;
+		size_t token_len;
+
+		while (oppo_cmdline_is_space(*src))
+			src++;
+		if (*src == '\0')
+			break;
+
+		token = src;
+		while (*src != '\0' && !oppo_cmdline_is_space(*src))
+			src++;
+		token_len = (size_t)(src - token);
+
+		if (oppo_minimal_cmdline_token_matches(token, token_len, pattern))
+			return true;
+	}
+
+	return false;
+}
+
+static bool oppo_minimal_append_token(char *cmdline, size_t cmdline_sz,
+				      size_t *out, const char *token,
+				      size_t token_len)
+{
+	if (token_len == 0)
+		return true;
+
+	if (*out != 0) {
+		if (*out + 1 >= cmdline_sz)
+			return false;
+		cmdline[(*out)++] = ' ';
+	}
+
+	if (*out + token_len >= cmdline_sz)
+		return false;
+
+	memcpy(cmdline + *out, token, token_len);
+	*out += token_len;
+	cmdline[*out] = '\0';
+	return true;
+}
+
+static void oppo_minimal_append_spaces(char *cmdline, size_t cmdline_sz,
+				       size_t *out, size_t count)
+{
+	if (count == 0)
+		return;
+
+	if (*out + count >= cmdline_sz)
+		panic("minimal normal cmdline overflow");
+
+	memset(cmdline + *out, ' ', count);
+	*out += count;
+	cmdline[*out] = '\0';
+}
+
+static void oppo_minimal_seed_chosen_bootargs(char *minimal,
+					      size_t minimal_sz,
+					      size_t *out)
+{
+	const char *src = cmdline_chosen_bootargs_get();
+	uint32_t removed = 0;
+
+	minimal[0] = '\0';
+	*out = 0;
+
+	if (src == NULL)
+		return;
+
+	while (*src != '\0') {
+		const char *token;
+		size_t token_len;
+
+		while (oppo_cmdline_is_space(*src))
+			src++;
+		if (*src == '\0')
+			break;
+
+		token = src;
+		while (*src != '\0' && !oppo_cmdline_is_space(*src))
+			src++;
+		token_len = (size_t)(src - token);
+
+		if (oppo_cmdline_token_has_prefix(token, token_len,
+						  "root=/dev/ram") ||
+		    oppo_cmdline_token_eq(token, token_len,
+					  "skip_initramfs")) {
+			removed++;
+			continue;
+		}
+
+		if (!oppo_minimal_append_token(minimal, minimal_sz, out,
+					       token, token_len))
+			panic("minimal chosen cmdline overflow");
+	}
+
+	if (removed)
+		dprintf(CRITICAL,
+			"[BOOT] chosen bootargs kept, removed non-stock root/initramfs tokens=%u\n",
+			removed);
+}
+
+static void oppo_minimal_append_if_missing(char *minimal, size_t minimal_sz,
+					   size_t *out, const char *pattern,
+					   const char *token)
+{
+	if (oppo_minimal_cmdline_has_token(minimal, pattern))
+		return;
+
+	if (!oppo_minimal_append_token(minimal, minimal_sz, out, token,
+				       strlen(token)))
+		panic("minimal normal cmdline overflow");
+}
+
+static bool oppo_cmdline_extract_token_value(const char *prefix,
+					     const char *fallback,
+					     char *out,
+					     size_t out_sz)
+{
+	const char *src = cmdline_get();
+	size_t prefix_len = strlen(prefix);
+	size_t copy_len;
+
+	if (out_sz == 0)
+		return false;
+
+	if (src != NULL) {
+		while (*src != '\0') {
+			const char *token;
+			size_t token_len;
+
+			while (oppo_cmdline_is_space(*src))
+				src++;
+			if (*src == '\0')
+				break;
+
+			token = src;
+			while (*src != '\0' && !oppo_cmdline_is_space(*src))
+				src++;
+			token_len = (size_t)(src - token);
+
+			if (token_len >= prefix_len &&
+			    memcmp(token, prefix, prefix_len) == 0) {
+				copy_len = token_len - prefix_len;
+				if (copy_len >= out_sz)
+					copy_len = out_sz - 1;
+				memcpy(out, token + prefix_len, copy_len);
+				out[copy_len] = '\0';
+				return true;
+			}
+		}
+	}
+
+	copy_len = strlen(fallback);
+	if (copy_len >= out_sz)
+		copy_len = out_sz - 1;
+	memcpy(out, fallback, copy_len);
+	out[copy_len] = '\0';
+	return false;
+}
