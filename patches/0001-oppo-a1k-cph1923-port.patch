+static void oppo_lk_wdt_force_off(void)
+{
+	static unsigned int done;
+	u32 mode;
+
+	if (done)
+		return;
+
+	mode = DRV_Reg32(MTK_WDT_MODE);
+	mode &= ~(MTK_WDT_MODE_ENABLE | MTK_WDT_MODE_EXT_POL |
+		  MTK_WDT_MODE_EXTEN | MTK_WDT_MODE_IRQ |
+		  MTK_WDT_MODE_IRQ_LEVEL_EN | MTK_WDT_MODE_AUTO_RESTART |
+		  MTK_WDT_MODE_DUAL_MODE);
+	mode |= MTK_WDT_MODE_KEY;
+	DRV_WriteReg32(MTK_WDT_MODE, mode);
+
+	done = 1;
+	WDTLOG("OPPO_LK_WDT_FULL_OFF: LK watchdog is fully off, MODE=0x%x\n",
+	       DRV_Reg32(MTK_WDT_MODE));
+}
+
+void mtk_wdt_disable(void)
+{
+	oppo_lk_wdt_force_off();
+}
