+static int oppo_add_stock_android_bootnodes(void *fdt, int android_offset)
+{
+	int vbmeta_offset;
+	int fstab_offset;
+	int vendor_offset;
+	int ret;
+
+	vbmeta_offset = fdt_path_offset(fdt, "/firmware/android/vbmeta");
+	if (vbmeta_offset < 0) {
+		vbmeta_offset = fdt_add_subnode(fdt, android_offset, "vbmeta");
+		if (vbmeta_offset < 0) {
+			dprintf(CRITICAL, "[FDT_ANDROID] can't add /firmware/android/vbmeta: %s\n",
+				fdt_strerror(vbmeta_offset));
+			return vbmeta_offset;
+		}
+	}
+
+	ret = fdt_setprop_string(fdt, vbmeta_offset, "compatible", "android,vbmeta");
+	if (!ret)
+		ret = fdt_setprop_string(fdt, vbmeta_offset, "parts",
+			"vbmeta,boot,system,vendor,recovery");
+	if (ret) {
+		dprintf(CRITICAL, "[FDT_ANDROID] set vbmeta node failed: %s\n",
+			fdt_strerror(ret));
+		return ret;
+	}
+
+	fstab_offset = fdt_path_offset(fdt, "/firmware/android/fstab");
+	if (fstab_offset < 0) {
+		fstab_offset = fdt_add_subnode(fdt, android_offset, "fstab");
+		if (fstab_offset < 0) {
+			dprintf(CRITICAL, "[FDT_ANDROID] can't add /firmware/android/fstab: %s\n",
+				fdt_strerror(fstab_offset));
+			return fstab_offset;
+		}
+	}
+
+	ret = fdt_setprop_string(fdt, fstab_offset, "compatible", "android,fstab");
+	if (ret) {
+		dprintf(CRITICAL, "[FDT_ANDROID] set fstab compatible failed: %s\n",
+			fdt_strerror(ret));
+		return ret;
+	}
+
+	vendor_offset = fdt_path_offset(fdt, "/firmware/android/fstab/vendor");
+	if (vendor_offset < 0) {
+		vendor_offset = fdt_add_subnode(fdt, fstab_offset, "vendor");
+		if (vendor_offset < 0) {
+			dprintf(CRITICAL, "[FDT_ANDROID] can't add vendor node: %s\n",
+				fdt_strerror(vendor_offset));
+			return vendor_offset;
+		}
+	}
+
+	ret = fdt_setprop_string(fdt, vendor_offset, "compatible", "android,vendor");
+	if (!ret)
+		ret = fdt_setprop_string(fdt, vendor_offset, "dev",
+			"/dev/block/platform/bootdevice/by-name/vendor");
+	if (!ret)
+		ret = fdt_setprop_string(fdt, vendor_offset, "type", "ext4");
+	if (!ret)
+		ret = fdt_setprop_string(fdt, vendor_offset, "mnt_flags", "ro");
+	if (!ret)
+		ret = fdt_setprop_string(fdt, vendor_offset, "fsmgr_flags", "wait,avb");
+
+	if (ret) {
+		dprintf(CRITICAL, "[FDT_ANDROID] set vendor fstab failed: %s\n",
+			fdt_strerror(ret));
+		return ret;
+	}
+
+	dprintf(CRITICAL, "[FDT_ANDROID] stock nodes ready vbmeta=%d fstab=%d vendor=%d\n",
+		vbmeta_offset, fstab_offset, vendor_offset);
+	return 0;
+}
