+int mtk_wdt_boot_check(void)
+{
+	int boot_reason;
+
+	if (g_boot_arg->maggic_number == BOOT_ARGUMENT_MAGIC) {
+		boot_reason = g_boot_arg->boot_reason;
+		WDTLOG("WDT full-off path keeps pre-loader boot reason %d\n",
+		       boot_reason);
+
+		if (boot_reason == BR_WDT)
