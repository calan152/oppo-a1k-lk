+static int fastboot_upload_buffer(void *data, unsigned size)
+{
+	char data_response[MAX_RSP_SIZE] __attribute__((aligned(64)));
+	unsigned sent = 0;
+
+	if (data == NULL || size == 0)
+		return -1;
+
+	memset(data_response, 0, sizeof(data_response));
+	snprintf(data_response, sizeof(data_response), "DATA%08x", size);
+	if (usb_write_with_timeout(data_response, strlen(data_response),
+			USB_CMD_TIMEOUT) < 0)
+		return -1;
+
+	while (sent < size) {
+		unsigned xfer = size - sent;
+
+		if (xfer > MAX_USBFS_BULK_SIZE)
+			xfer = MAX_USBFS_BULK_SIZE;
+
+		mtk_wdt_restart();
+		if (usb_write_with_timeout((unsigned char *)data + sent, xfer,
+				USB_CMD_TIMEOUT) < 0)
+			return -1;
+		sent += xfer;
+	}
+
+	return 0;
+}
+
+static int fastboot_stage_partition(const char *part_name)
+{
+	u64 part_size;
+	ssize_t read_len;
+
+	if (download_base == NULL)
+		return -1;
+
+	part_size = partition_get_size_by_name(part_name);
+	if (part_size == 0)
+		return -2;
+
+	if (part_size > download_max || part_size > 0xffffffffULL)
+		return -3;
+
+	dprintf(ALWAYS, "[fastboot_dump] stage %s size=0x%llx base=0x%x\n",
+		part_name, part_size, (unsigned int)download_base);
+
+	read_len = partition_read(part_name, 0, (u8 *)download_base,
+		(size_t)part_size);
+	if (read_len != (ssize_t)part_size) {
+		dprintf(ALWAYS, "[fastboot_dump] read %s failed: %d/0x%llx\n",
+			part_name, (int)read_len, part_size);
+		return -4;
+	}
+
+	download_size = (unsigned)part_size;
+	return 0;
+}
+
+static void fastboot_fail_stage_result(int ret)
+{
+	switch (ret) {
+	case -1:
+		fastboot_fail("download buffer is null");
+		break;
+	case -2:
+		fastboot_fail("expdb partition not found");
+		break;
+	case -3:
+		fastboot_fail("expdb too large");
+		break;
+	case -4:
+		fastboot_fail("expdb read failed");
+		break;
+	default:
+		fastboot_fail("expdb stage failed");
+		break;
+	}
+}
+
+void cmd_upload(const char *arg, void *data, unsigned sz)
+{
+	if (download_base == NULL || download_size == 0) {
+		fastboot_fail("no staged data");
+		return;
+	}
+
+	dprintf(ALWAYS, "[fastboot_dump] upload staged size=0x%x\n",
+		download_size);
+	if (fastboot_upload_buffer(download_base, download_size) < 0)
+		return;
+
+	fastboot_okay("");
+}
+
+void cmd_dump_expdb(const char *arg, void *data, unsigned sz)
+{
+	int ret = fastboot_stage_partition("expdb");
+
+	if (ret < 0) {
+		fastboot_fail_stage_result(ret);
+		return;
+	}
+
+	dprintf(ALWAYS, "[fastboot_dump] stream expdb size=0x%x\n",
+		download_size);
+	if (fastboot_upload_buffer(download_base, download_size) < 0)
+		return;
+
+	fastboot_okay("");
+}
+
+void cmd_fetch_partition(const char *arg, void *data, unsigned sz)
+{
+	char part_name[64];
+	char *offset_arg;
+	char *size_arg;
+	u64 part_size;
+	unsigned long offset;
