+	mt_set_gpio_mode(rst_pin, GPIO_MODE_00);
+	mt_set_gpio_dir(rst_pin, GPIO_DIR_OUT);
+	mt_set_gpio_out(rst_pin, value ? GPIO_OUT_ONE : GPIO_OUT_ZERO);
+	dprintf(0, "[OPPO_DSI] lcm rst gpio=%d value=%u\n",
+		rst_pin & ~PIN_ENCRYPT, value);
 }
 
