+	datasize = kedump_dev_write(offset, (uint64_t)(uint32_t)logbuf, SZLOG);
+	kedump_add2hdr(offset, SZLOG, datasize, "ZAEE_LOG");
+	offset += datasize;
+
+	ram_console_set_dump_step(AEE_LKDUMP_CLEAR);
